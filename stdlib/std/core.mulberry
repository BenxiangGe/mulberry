package std.core;

comptime Char = UInt8;

extern fn mulberry_u8_to_u64(value: UInt8): UInt64;

fn identity(value: UInt64): UInt64 {
  value
}

fn toUInt64(value: UInt8): UInt64 {
  mulberry_u8_to_u64(value)
}

fn boolToUInt64(value: Bool): UInt64 {
  var result: UInt64 = 0;
  if value {
    result = 1;
  }
  result
}
