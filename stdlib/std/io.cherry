package std.io;

import string.String;

struct FileStorage {
  handle: Ptr<UInt8>
}

comptime File = Ptr<FileStorage>;

fn print(value: UInt64): UInt64 {
  builtinPrint(value)
}

fn open(path: String, mode: String): File {
  builtinOpen(path, mode)
}

fn close(file: File): UInt64 {
  builtinClose(file)
}
