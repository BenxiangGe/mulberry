# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  io.println(20 + 10);
  io.println(18446744073709551615 + 0);
  io.println(18446744073709551615 + 1);

  io.println(20 - 10);
  io.println(0 - 1);

  io.println(20 * 10);

  io.println(20 / 10);
  io.println(20 / 3);

  io.println(20 % 10);
  io.println(20 % 3);

  io.println(boolToUInt64(20 < 10));
  io.println(boolToUInt64(10 < 20));
  io.println(boolToUInt64(10 < 10));

  io.println(boolToUInt64(20 <= 10));
  io.println(boolToUInt64(10 <= 20));
  io.println(boolToUInt64(10 <= 10));

  io.println(boolToUInt64(20 > 10));
  io.println(boolToUInt64(10 > 20));
  io.println(boolToUInt64(10 > 10));

  io.println(boolToUInt64(20 >= 10));
  io.println(boolToUInt64(10 >= 20));
  io.println(boolToUInt64(10 >= 10));

  io.println(boolToUInt64(20 == 10));
  io.println(boolToUInt64(10 >= 20));
  io.println(boolToUInt64(10 == 10));

  io.println(boolToUInt64(20 != 10));
  io.println(boolToUInt64(10 != 20));
  io.println(boolToUInt64(10 != 10));

  io.println(boolToUInt64(true == true));
  io.println(boolToUInt64(true == false));

  io.println(boolToUInt64(true != true));
  io.println(boolToUInt64(true != false));

  io.println(boolToUInt64(false and false));
  io.println(boolToUInt64(false and true));
  io.println(boolToUInt64(true and false));
  io.println(boolToUInt64(true and true));

  io.println(boolToUInt64(false or false));
  io.println(boolToUInt64(false or true));
  io.println(boolToUInt64(true or false));
  io.println(boolToUInt64(true or true));

  return 0;
}

# CHECK: arith.addi
# CHECK: arith.subi
# CHECK: arith.muli
# CHECK: arith.divui
# CHECK: arith.remui
# CHECK: arith.cmpi ult
# CHECK: arith.cmpi ule
# CHECK: arith.cmpi ugt
# CHECK: arith.cmpi uge
# CHECK: arith.cmpi eq
# CHECK: arith.cmpi ne
# CHECK: arith.andi
# CHECK: arith.ori
# CHECK: call @std.core.boolToUInt64
# CHECK: call @std_io_println__UInt64
# CHECK-NOT: cir.
