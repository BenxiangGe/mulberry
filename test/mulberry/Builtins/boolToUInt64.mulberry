# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  io.println(boolToUInt64(true));
  
  io.println(boolToUInt64(false));

  return 0;
}

# CHECK-LABEL: func.func @std.core.boolToUInt64
# CHECK: scf.if
# CHECK: call @std_io_println__UInt64
# CHECK: call @std_io_println__UInt64
# CHECK-NOT: cir.
