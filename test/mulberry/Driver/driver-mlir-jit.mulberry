# RUN: mulberry-driver %s -dump=mlir-llvm 2>&1 | FileCheck %s --check-prefix=MLIRLLVM
# RUN: mulberry-driver %s -dump=llvm 2>&1 | FileCheck %s --check-prefix=LLVM
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn bar(x: UInt64, y: Bool): Bool {
  var k = y;
  
  if k {
    io.println(18446744073709551615);
    k = false;
  } else {
    io.println(1);
    k = true;
  }

  while k {
    k = false;
  }

  return k;
}

fn baz(): () {
  return;
}

fn main(): UInt64 {
  0 % 3 * 8 / 4 + 3 - 1;
  3 < 1; 3 <= 1; 3 > 1; 3 >= 1;
  true and false or true == false != true;

  var boolValue = bar(18446744073709551615, false);
  io.println(boolToUInt64(boolValue));
  baz();
  return 0;
}

# MLIRLLVM-DAG: llvm.func private @writeString
# MLIRLLVM-DAG: llvm.func @_mlir_ciface_writeString
# MLIRLLVM: llvm.func @main() -> i64
# MLIRLLVM: llvm.call @std_io_println__UInt64
# MLIRLLVM: llvm.func @_mlir_ciface_main() -> i64
# MLIRLLVM: llvm.func @std_io_println__UInt64
# MLIRLLVM: llvm.call @std_io_print__UInt64
# MLIRLLVM: llvm.func @std_io_print__UInt64
# MLIRLLVM-NOT: mulberry.
# MLIRLLVM-NOT: func.func
# MLIRLLVM-NOT: builtin.unrealized_conversion_cast

# LLVM-DAG: define private void @writeString
# LLVM-DAG: declare void @_mlir_ciface_writeString
# LLVM: define i64 @main()
# LLVM: call void @std_io_println__UInt64
# LLVM: define i64 @_mlir_ciface_main()
# LLVM: define void @std_io_println__UInt64
# LLVM: call void @std_io_print__UInt64
# LLVM: define void @std_io_print__UInt64

# JIT: 1
# JIT-NEXT: 0
