# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT
# RUN: mulberry-driver %s -c=%t.o
# RUN: test -s %t.o
# RUN: mulberry-driver %s -o %t.exe
# RUN: %t.exe 2>&1 | FileCheck %s --check-prefix=JIT
# RUN: mkdir -p %t.bundle
# RUN: mulberry-driver %s -o %t.bundle/driver --bundle-runtime
# RUN: test -s %t.bundle/driver
# RUN: test -s %t.bundle/libmulberry_runtime.so
# RUN: ls %t.bundle/libmlir_c_runner_utils.so* >/dev/null
# RUN: ls %t.bundle/libmlir_apfloat_wrappers.so* >/dev/null
# RUN: ls %t.bundle/libmlir_float16_utils.so* >/dev/null
# RUN: ls %t.bundle/libgc.so* >/dev/null
# RUN: %t.bundle/driver 2>&1 | FileCheck %s --check-prefix=JIT
# RUN: not mulberry-driver %s -c=%t.o -o %t.exe 2>&1 | FileCheck %s --check-prefix=BAD-OUTPUT
# RUN: not mulberry-driver %s --bundle-runtime 2>&1 | FileCheck %s --check-prefix=BAD-BUNDLE

struct A { }

struct B {
  x: Bool,
  y: A
}

fn bar(x: UInt64, y: Bool): B {
  var k = y;
  
  if k {
    io.println(18446744073709551615);
    k = false;
  } else {
    io.println(1);
    k = true;
  }

  while k {
    k = false;
  }

  return B { k, A {} };
}

fn baz(): () {
  return;
}

fn main(): UInt64 {
  0 % 3 * 8 / 4 + 3 - 1;
  3 < 1; 3 <= 1; 3 > 1; 3 >= 1;
  true and false or true == false != true;

  var structValue = bar(18446744073709551615, false);
  io.println(boolToUInt64(structValue.x));
  baz();
  return 0;
}

# JIT: 1
# JIT-NEXT: 0
# BAD-OUTPUT: error: -c and -o cannot be used together
# BAD-BUNDLE: error: --bundle-runtime requires -o
