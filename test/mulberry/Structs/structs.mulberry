# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct A { }

struct B {
  a: A,
  y: UInt64
}

struct C {
  b: B,
  x: UInt64
}

fn main(): UInt64 {
  var c = C { B { A {}, 2 }, 1 };
  io.println(c.x);
  c.x = 11;
  io.println(c.x);

  io.println(c.b.y);
  c.b.y = 22;
  io.println(c.b.y);
  return 0;
}

# CHECK: !mulberry_core.record<C
# CHECK-SAME: !mulberry_core.record<B
# CHECK-SAME: !mulberry_core.record<A {}
# CHECK: mulberry_core.record.get_field
# CHECK: mulberry_core.store
# CHECK: call @std_io_println__UInt64
# CHECK-NOT: cir.
