# RUN: mulberry-driver --dump=mlir %s 2>&1 | FileCheck %s

struct Pair {
  x: UInt64,
  y: UInt64
}

struct Box {
  pair: Pair,
  ok: Bool
}

fn makePair(x: UInt64): Pair {
  return Pair { x, x + 1 };
}

fn readX(box: Box): UInt64 {
  return box.pair.x;
}

fn update(mut box: Box): Box {
  var copy: Box = box;
  copy.pair.x = copy.pair.y;
  copy.ok = false;
  return copy;
}

fn main(): UInt64 {
  var box: Box = Box { makePair(4), true };
  var changed: Box = update(box);
  return readX(changed);
}

# CHECK-LABEL: func.func @makePair
# CHECK-SAME: (%arg0: i64)
# CHECK-SAME: -> !mulberry_core.ptr<!mulberry_core.record<Pair
# CHECK: mulberry_core.heap.alloc !mulberry_core.record<Pair
# CHECK: arith.addi
# CHECK: return {{.*}} : !mulberry_core.ptr<!mulberry_core.record<Pair

# CHECK-LABEL: func.func @readX
# CHECK-SAME: !mulberry_core.ptr<!mulberry_core.record<Box
# CHECK: mulberry_core.record.get_field {{.*}}["pair"]
# CHECK: mulberry_core.record.get_field {{.*}}["x"]
# CHECK: return {{.*}} : i64

# CHECK-LABEL: func.func @update
# CHECK-SAME: !mulberry_core.ptr<!mulberry_core.record<Box
# CHECK-SAME: -> !mulberry_core.ptr<!mulberry_core.record<Box
# CHECK: mulberry_core.record.get_field {{.*}}["pair"]
# CHECK: mulberry_core.record.get_field {{.*}}["x"]
# CHECK: mulberry_core.record.get_field {{.*}}["pair"]
# CHECK: mulberry_core.record.get_field {{.*}}["y"]
# CHECK: mulberry_core.store
# CHECK: mulberry_core.record.get_field {{.*}}["ok"]
# CHECK: arith.constant false
# CHECK: return {{.*}} : !mulberry_core.ptr<!mulberry_core.record<Box

# CHECK-LABEL: func.func @main
# CHECK: call @makePair
# CHECK: call @update
# CHECK: call @readX
# CHECK-NOT: cir.
