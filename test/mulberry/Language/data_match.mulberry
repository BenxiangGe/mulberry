# LOWERED: llvm.load {{.*}} : !llvm.ptr -> i64
# LOWERED: llvm.getelementptr
# LOWERED: llvm.load {{.*}} : !llvm.ptr -> i64
# LOWERED-LABEL: func.func @sum(
# LOWERED: llvm.getelementptr
# LOWERED: llvm.load {{.*}} : !llvm.ptr -> !llvm.ptr
# LOWERED-LABEL: func.func @apply(
# LOWERED: func.call_indirect
# LOWERED-NOT: mulberry_core.

