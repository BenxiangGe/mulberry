# MLIR-DAG: call @std_string_formatValue__UInt8
# MLIR-DAG: call @std_string_formatValue__UInt64
# MLIR-DAG: call @std_string_formatValue__Float32
# MLIR-DAG: call @std_string_formatValue__Point
