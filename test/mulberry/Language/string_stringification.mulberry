# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Point {
  x: UInt64,
  y: UInt64,

  pub fn toString(self: Point): String {
    return "Point({$self.x}, {$self.y})";
  }
}

struct Plain {
  value: UInt64
}

comptime Box<T> = struct {
  value: T,

  pub fn toString(self: Box<T>): String {
    return "Box({$self.value})";
  }
};

comptime PlainBox<T> = struct {
  value: T
};

fn decorate<T>(value: T): String {
  return "<{$value}>";
}

fn main(): UInt64 {
  const truth = true;
  const byte = core.toUInt8(7);
  const count = 18446744073709551615;
  const loss = 3.5;
  const point = Point { 4, 9 };
  const plain = Plain { 11 };
  const alias = plain;
  const values = [1, 2];
  const box: Box<UInt64> = Box<UInt64> { 12 };
  const plainBox: PlainBox<UInt64> = PlainBox<UInt64> { 13 };

  io.writeText("scalars {$truth} {$byte} {$count} {$loss}");
  io.writeText("\n");
  io.writeText("custom {$point}");
  io.writeText("\n");
  io.writeText("count=" + count + ", point=" + point);
  io.writeText("\n");
  io.writeText("plain " + plain);
  io.writeText("\n");
  io.writeText("alias {$alias}");
  io.writeText("\n");
  io.writeText("array {$values}");
  io.writeText("\n");
  io.writeText("generic " + decorate(count) + " " + decorate(point));
  io.writeText("\n");
  io.writeText("boxes {$box} {$plainBox}");
  io.writeText("\n");
  return 0;
}

# AST-DAG: TraitDecl {{.*}}name=std.string.Show
# AST-DAG: TraitMethodDecl {{.*}}name=toString receiver=readonly return=String
# AST-DAG: Prototype {{.*}}name=std.string.formatValue parameter=T: Show
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__Bool
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__UInt8
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__UInt64
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__Float32
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__Point
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__Plain
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__Array_UInt64__2_
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__Box__UInt64
# AST-DAG: CallExpr {{.*}}callee=std_string_formatValue__PlainBox__UInt64
# AST-DAG: CallExpr {{.*}}callee=std.string.Show__UInt64.toString
# AST-DAG: CallExpr {{.*}}callee=std.string.Show__Bool.toString
# AST-DAG: CallExpr {{.*}}callee=std.string.Show__UInt8.toString
# AST-DAG: CallExpr {{.*}}callee=std.string.Show__Float32.toString
# AST-DAG: CallExpr {{.*}}callee=Point.toString
# AST-DAG: CallExpr {{.*}}callee=std_string_objectToString__Plain
# AST-DAG: CallExpr {{.*}}callee=std_string_objectToString__Array_UInt64__2_
# AST-DAG: CallExpr {{.*}}callee=Box_toString__UInt64
# AST-DAG: CallExpr {{.*}}callee=std_string_objectToString__PlainBox__UInt64

