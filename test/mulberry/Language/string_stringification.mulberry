# JIT: scalars true 7 18446744073709551615 3.5
# JIT-NEXT: custom Point(4, 9)
# JIT-NEXT: count=18446744073709551615, point=Point(4, 9)
# JIT-NEXT: plain Plain@0x[[IDENTITY:[0-9a-f]+]]
# JIT-NEXT: alias Plain@0x[[IDENTITY]]
# JIT-NEXT: array Array<UInt64, 2>@0x{{[0-9a-f]+}}
# JIT-NEXT: generic <18446744073709551615> <Point(4, 9)>
