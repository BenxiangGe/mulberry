# AST-DAG: DataConstructorDecl {{.*}}name=ByName payloadTypes=String
# AST-DAG: DataConstructorDecl {{.*}}name=ByIdAndName payloadTypes=UInt64, String
# AST: DataDecl {{.*}}name=Tree parameter=T
# AST-DAG: DataConstructorDecl {{.*}}name=Empty payloadTypes=
# AST-DAG: DataConstructorDecl {{.*}}name=Node payloadTypes=T, Tree<T>, Tree<T>
# AST: DataDecl {{.*}}name=Either parameter=L, R
# AST-DAG: DataConstructorDecl {{.*}}name=Left payloadTypes=L
# AST-DAG: DataConstructorDecl {{.*}}name=Right payloadTypes=R
# AST-DAG: DataConstructorExpr {{.*}}type=LookupKey constructor=ById tag=0
# AST-DAG: DataConstructorExpr {{.*}}type=LookupKey constructor=ByName tag=1
# AST-DAG: DataConstructorExpr {{.*}}type=LookupKey constructor=ByIdAndName tag=2
# AST-DAG: DataConstructorExpr {{.*}}type=Tree<UInt64> constructor=Node tag=1
# AST-DAG: DataConstructorExpr {{.*}}type=Tree<UInt64> constructor=Empty tag=0
# AST-DAG: DataConstructorExpr {{.*}}type=Either<UInt64, std.string.String> constructor=Left tag=0
# AST-DAG: DataConstructorExpr {{.*}}type=Either<UInt64, std.string.String> constructor=Right tag=1

