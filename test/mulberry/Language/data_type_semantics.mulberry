# MLIR: mulberry_core.data.construct "ById"[0] ({{.*}}) : (i64) -> !mulberry_core.ptr<!mulberry_core.data<"LookupKey">>
# MLIR-LABEL: func.func @nameKey() -> !mulberry_core.ptr<!mulberry_core.data<"LookupKey">>
# MLIR: mulberry_core.data.construct "ByName"[1]
# MLIR-SAME: !mulberry_core.ptr<!mulberry_core.record<std.string.String
