# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

data LookupKey =
    ById(UInt64)
  | ByName(String)
  | ByIdAndName(UInt64, String);

data Tree<T> =
    Empty
  | Node(T, Tree<T>, Tree<T>);

data Either<L, R> =
    Left(L)
  | Right(R);

fn idKey(): LookupKey {
  return ById(42);
}

fn nameKey(): LookupKey {
  return ByName("Mulberry");
}

fn pairKey(): LookupKey {
  return ByIdAndName(42, "Mulberry");
}

fn tree(): Tree<UInt64> {
  return Node(2,
              Node(1, Empty(), Empty()),
              Node(3, Empty(), Empty()));
}

fn left(): Either<UInt64, String> {
  return Left(42);
}

fn right(): Either<UInt64, String> {
  return Right("Mulberry");
}

fn passthrough(key: LookupKey): LookupKey {
  return key;
}

fn main(): UInt64 {
  const byId: LookupKey = passthrough(idKey());
  const byName: LookupKey = nameKey();
  const byBoth: LookupKey = pairKey();
  const numbers: Tree<UInt64> = tree();
  const leftValue: Either<UInt64, String> = left();
  const rightValue: Either<UInt64, String> = right();
  io.println(42);
  return 0;
}

