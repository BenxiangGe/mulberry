# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var xs: List<UInt64> = [];
  xs.push(42);
  xs.push(58);
  io.print(xs.size());
  io.print(xs[0] + xs[1]);
  0
}

# AST: ComptimeTypeAliasDecl {{.*}}name=std.collections.List parameter=T
# AST: VariableStat {{.*}}id=xs{{.*}}type=List<UInt64>
# AST: ArrayLiteralExpr {{.*}}type=std_collections_List__UInt64
# AST-DAG: CallExpr {{.*}}callee=std_collections_List_push__UInt64
# AST-DAG: IndexExpr {{.*}}type=UInt64 kind=stdlibList

# MLIR-LABEL: func.func @main()
# MLIR: call @std_collections_withCapacity__UInt64
# MLIR-DAG: func.func @std_collections_withCapacity__UInt64
# MLIR-DAG: func.func @std_collections_List_grow__UInt64
# MLIR-DAG: scf.while
# MLIR-DAG: call @std_collections_List_push__UInt64

