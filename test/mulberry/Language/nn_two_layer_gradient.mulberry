# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import mulberry.nn;

fn main(): UInt64 {
  var w1 = tensor.from([[0.0, 0.0], [0.0, 0.0]]);
  var b1 = tensor.from([[0.0], [0.0]]);
  var w2 = tensor.from([[0.0, 0.0], [0.0, 0.0]]);
  var b2 = tensor.from([[0.0], [0.0]]);
  var x = tensor.from([[1.0], [0.0]]);
  var y = tensor.from([[1.0], [0.0]]);

  var weights = list.from([w1, w2]);
  var biases = list.from([b1, b2]);
  const gradient =
      nn.twoLayerGradient(weights, biases, x, y);

  io.println(gradient.w1.numel());
  io.println(core.boolToUInt64(gradient.w2[0, 0] < 0.0));
  io.println(core.boolToUInt64(gradient.w2[1, 1] > 0.0));
  io.println(core.boolToUInt64(gradient.b2[0, 0] < 0.0));
  io.println(core.boolToUInt64(gradient.b2[1, 0] > 0.0));
  return 0;
}

# JIT: 4
# JIT-NEXT: 1
# JIT-NEXT: 1
# JIT-NEXT: 1
# JIT-NEXT: 1
