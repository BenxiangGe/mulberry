struct Pair {
  x: UInt64,
  y: UInt64
}

fn main(): UInt64 {
  var xs: List<Pair> = list.from([Pair { 10, 32 }, Pair { 4, 9 }]);
  io.print(xs.size());
  io.print(xs[0].x + xs[1].y);
  0
}

