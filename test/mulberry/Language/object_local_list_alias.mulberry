# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

fn main(): UInt64 {
  var xs = list.from([1]);
  var ys = xs;
  ys.push(2);
  io.println(xs.size());
  return 0;
}

