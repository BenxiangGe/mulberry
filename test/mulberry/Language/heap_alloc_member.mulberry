# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct Pair {
  x: UInt64,
  y: Bool
}

fn direct(): UInt64 {
  heap.alloc<Pair>().x = 7;
  0
}

fn viaVariable(): UInt64 {
  var p: Ptr<Pair> = heap.alloc<Pair>();
  p.x = 8;
  p.x
}

fn main(): UInt64 {
  0
}

# CHECK-LABEL: func.func @direct()
# CHECK: %[[ONE:.*]] = arith.constant 1 : index
# CHECK: %[[DIRECT:.*]] = mulberry_core.heap.alloc !mulberry_core.record<Pair{{.*}}, %[[ONE]]
# CHECK: %[[DIRECT_X:.*]] = mulberry_core.record.get_field %[[DIRECT]]["x"]
# CHECK: mulberry_core.store

# CHECK-LABEL: func.func @viaVariable()
# CHECK: %[[ONE:.*]] = arith.constant 1 : index
# CHECK: %[[PAIR:.*]] = mulberry_core.heap.alloc !mulberry_core.record<Pair{{.*}}, %[[ONE]]
# CHECK: mulberry_core.store %[[PAIR]]
# CHECK: %[[CURRENT:.*]] = mulberry_core.load {{.*}} : !mulberry_core.ptr<!mulberry_core.ptr<!mulberry_core.record<Pair{{.*}}> -> !mulberry_core.ptr<!mulberry_core.record<Pair
# CHECK: %[[X:.*]] = mulberry_core.record.get_field %[[CURRENT]]["x"]
# CHECK: mulberry_core.store
# CHECK: %[[CURRENT2:.*]] = mulberry_core.load {{.*}} : !mulberry_core.ptr<!mulberry_core.ptr<!mulberry_core.record<Pair{{.*}}> -> !mulberry_core.ptr<!mulberry_core.record<Pair
# CHECK: %[[X2:.*]] = mulberry_core.record.get_field %[[CURRENT2]]["x"]
# CHECK: mulberry_core.load %[[X2]]
