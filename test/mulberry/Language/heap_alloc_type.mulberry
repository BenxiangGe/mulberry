# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

struct Pair {
  x: UInt64,
  y: Bool
}

fn makeUInt64(): Ptr<UInt64> {
  heap.alloc<UInt64>()
}

fn makePair(): Ptr<Pair> {
  heap.alloc<Pair>()
}

fn makeList(): Ptr<List<UInt64>> {
  heap.alloc<List<UInt64>>()
}

fn main(): UInt64 {
  0
}

# AST: HeapAllocExpr {{.*}}type=Ptr<UInt64> allocated=UInt64
# AST: HeapAllocExpr {{.*}}type=Ptr<Pair> allocated=Pair
# AST: HeapAllocExpr {{.*}}type=Ptr<std_list_List__UInt64> allocated=std_list_List__UInt64

# MLIR-LABEL: func.func @makeUInt64() -> !mulberry_core.ptr<i64>
# MLIR: %[[ONE:.*]] = arith.constant 1 : index
# MLIR: mulberry_core.heap.alloc i64, %[[ONE]] : !mulberry_core.ptr<i64>
# MLIR-LABEL: func.func @makePair() -> !mulberry_core.ptr<!mulberry_core.record<Pair
# MLIR: %[[ONE:.*]] = arith.constant 1 : index
# MLIR: mulberry_core.heap.alloc !mulberry_core.record<Pair{{.*}}, %[[ONE]]
# MLIR-LABEL: func.func @makeList() -> !mulberry_core.ptr<!mulberry_core.record<std_list_List__UInt64
# MLIR: %[[ONE:.*]] = arith.constant 1 : index
# MLIR: mulberry_core.heap.alloc !mulberry_core.record<std_list_List__UInt64{{.*}}, %[[ONE]]
