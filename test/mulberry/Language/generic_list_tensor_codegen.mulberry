# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn first(weights: List<Tensor<Float32>>): Tensor<Float32> {
  return weights[0];
}

fn make(): List<Tensor<Float32>> {
  var w1 = tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var w2 = tensor.from([[5.0, 6.0]]);
  var weights = list.from([w1, w2]);
  return weights;
}

fn main(): UInt64 {
  var w1 = tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var w2 = tensor.from([[5.0, 6.0]]);
  var weights = list.from([w1, w2]);
  const layer = first(weights);
  return layer.numel() + make().size();
}

# CHECK-LABEL: func.func @first(%arg0: !mulberry_core.ptr<!mulberry_core.record<std_list_List__
# CHECK-SAME: -> !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# CHECK: call @std_list_List_get__
# CHECK-LABEL: func.func @make()
# CHECK-SAME: -> !mulberry_core.ptr<!mulberry_core.record<std_list_List__
# CHECK: mulberry_core.heap.alloc f32
# CHECK: mulberry_core.record.get_field {{.*}}["data"]
# CHECK: mulberry_core.record.get_field {{.*}}["strides"]
# CHECK: call @std_list_from__std_tensor_Tensor__Float32__2
# CHECK-LABEL: func.func @main()
# CHECK: call @std_list_from__std_tensor_Tensor__Float32__2
# CHECK: call @first
# CHECK: call @std_tensor_Tensor_numel__Float32
# CHECK: call @make
# CHECK: call @std_list_List_size__
