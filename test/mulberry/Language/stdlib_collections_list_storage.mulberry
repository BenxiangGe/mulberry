# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var xs: List<UInt64> = list.from([42, 58]);
  io.println(xs.size());
  io.println(xs[0] + xs[1]);
  return 0;
}

# AST: ComptimeTypeAliasDecl {{.*}}name=std.list.List parameter=T
# AST-DAG: CallExpr {{.*}}callee=std_list_from__UInt64__2
# AST-DAG: CallExpr {{.*}}callee=std_list_List_size__UInt64
# AST-DAG: IndexExpr {{.*}}type=UInt64 kind=stdlibList

# MLIR-LABEL: func.func @main()
# MLIR: call @std_list_from__UInt64__2
# MLIR: call @std_list_List_size__UInt64
# MLIR: call @std_list_List_get__UInt64
# MLIR-DAG: func.func @std_list_List_size__UInt64
# MLIR-DAG: func.func @std_list_List_get__UInt64

# JIT: 2
# JIT-NEXT: 100
