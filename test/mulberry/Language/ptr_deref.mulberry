# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct Pair {
  x: UInt64,
  y: Bool
}

fn scalar(): UInt64 {
  var p: Ptr<UInt64> = heap.alloc<UInt64>();
  *p = 42;
  *p
}

fn record(): UInt64 {
  var p: Ptr<Pair> = heap.alloc<Pair>();
  p.x = 7;
  var value: Pair = *p;
  value.x
}

fn main(): UInt64 {
  0
}

# CHECK-LABEL: func.func @scalar()
# CHECK: %[[ONE:.*]] = arith.constant 1 : index
# CHECK: %[[PTR:.*]] = mulberry_core.heap.alloc i64, %[[ONE]] : !mulberry_core.ptr<i64>
# CHECK: mulberry_core.store %[[PTR]]
# CHECK: %[[CURRENT:.*]] = mulberry_core.load {{.*}} : !mulberry_core.ptr<!mulberry_core.ptr<i64>> -> !mulberry_core.ptr<i64>
# CHECK: mulberry_core.store {{.*}}, %[[CURRENT]] : i64, !mulberry_core.ptr<i64>
# CHECK: %[[VALUE_PTR:.*]] = mulberry_core.load {{.*}} : !mulberry_core.ptr<!mulberry_core.ptr<i64>> -> !mulberry_core.ptr<i64>
# CHECK: %[[VALUE:.*]] = mulberry_core.load %[[VALUE_PTR]] : !mulberry_core.ptr<i64> -> i64
# CHECK: return %[[VALUE]] : i64

# CHECK-LABEL: func.func @record()
# CHECK: %[[ONE:.*]] = arith.constant 1 : index
# CHECK: %[[PAIR:.*]] = mulberry_core.heap.alloc !mulberry_core.record<Pair{{.*}}, %[[ONE]]
# CHECK: mulberry_core.store %[[PAIR]]
# CHECK: %[[PAIR_CURRENT:.*]] = mulberry_core.load {{.*}} : !mulberry_core.ptr<!mulberry_core.ptr<!mulberry_core.record<Pair{{.*}}> -> !mulberry_core.ptr<!mulberry_core.record<Pair
# CHECK: mulberry_core.record.get_field %[[PAIR_CURRENT]]["x"]
# CHECK: %[[VALUE_PTR:.*]] = mulberry_core.load {{.*}} : !mulberry_core.ptr<!mulberry_core.ptr<!mulberry_core.record<Pair{{.*}}> -> !mulberry_core.ptr<!mulberry_core.record<Pair
# CHECK: %[[VALUE:.*]] = mulberry_core.load %[[VALUE_PTR]] : !mulberry_core.ptr<!mulberry_core.record<Pair
# CHECK: mulberry_core.store %[[VALUE]]
# CHECK: mulberry_core.record.get_field
