# RUN: mulberry-driver --dump=mlir %s 2>&1 | FileCheck %s

struct A {
  x: UInt64,
  flag: Bool
}

fn add(x: UInt64): UInt64 {
  x + 1
}

fn main(): UInt64 {
  var a: A = A { 1, true };
  var sum: UInt64 = 0;

  for i in 0 .. 2 {
    sum = sum + i;
  }

  if a.flag {
    add(sum)
  } else {
    0
  }
}

# CHECK-LABEL: module {
# CHECK-LABEL: func.func @add
# CHECK: mulberry_core.alloca i64 : !mulberry_core.ptr<i64>
# CHECK: arith.addi
# CHECK: return
# CHECK-LABEL: func.func @main
# CHECK: mulberry_core.alloca !mulberry_core.record<A
# CHECK: mulberry_core.record.get_field
# CHECK: mulberry_core.store
# CHECK: scf.for unsigned
# CHECK: arith.addi
# CHECK: scf.if {{.*}} -> (i64)
# CHECK: call @add
# CHECK-NOT: cir.
