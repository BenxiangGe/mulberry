# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

comptime LocalVector<T> = List<T>;

fn first(xs: LocalVector<UInt64>): UInt64 {
  return xs[0];
}

fn main(): UInt64 {
  var xs: LocalVector<UInt64> = list.from([9, 8]);
  return first(xs);
}

# CHECK: func.func @first(%arg0: !mulberry_core.ptr<!mulberry_core.record<std_list_List__UInt64
# CHECK-SAME: -> i64
# CHECK: call @std_list_List_get__UInt64
