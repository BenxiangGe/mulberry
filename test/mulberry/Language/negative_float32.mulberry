# RUN: mulberry-driver -dump=tokens %s 2>&1 | FileCheck %s --check-prefix=TOKENS
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

fn main(): UInt64 {
  var x: Float32 = -1.25;
  var values: Float32[2] = [-1.25, -2.5e1];

  0
}

# TOKENS: diff '-'
# TOKENS: float_literal '1.25'
# TOKENS: diff '-'
# TOKENS: float_literal '1.25'
# TOKENS: diff '-'
# TOKENS: float_literal '2.5e1'

# AST: FloatLiteralExpr
# AST-SAME: type=Float32 value=-1.25

# MLIR: arith.constant -1.250000e+00 : f32
# MLIR: arith.constant -2.500000e+01 : f32
# MLIR-NOT: cir.
