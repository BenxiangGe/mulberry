# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var data: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var packedTensor: Tensor<Float32> = tensor.pack(data);
  var view: Float32[?, ?] = tensor.view(packedTensor);
  io.print(packedTensor.numel());
  io.print(boolToUInt64(view[1, 1] > 3.5));
  0
}

# AST: VariableStat (id=packedTensor
# AST-SAME: type=Tensor<Float32>
# AST-SAME: origin=std.tensor.Tensor<Float32>
# AST: TensorPackExpr {{.*}}type=std_tensor_Tensor__Float32

# MLIR: mulberry.tensor.pack
# MLIR-SAME: -> !mulberry.record<std_tensor_Tensor__Float32

# LOWERED-NOT: mulberry.tensor.pack
# LOWERED-NOT: mulberry.tensor.view
# LOWERED: memref.copy

# JIT: 4
# JIT-NEXT: 1
