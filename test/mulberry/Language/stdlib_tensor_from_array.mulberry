# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var values: Array<Array<Float32, 2>, 2> =
      [[1.0, 2.0], [3.0, 4.0]];
  var matrix: Tensor<Float32> = tensor.from(values);
  var bytes: Tensor<UInt64> = tensor.from([10, 20, 30]);

  io.print(matrix.numel());
  io.print(boolToUInt64(matrix[1, 1] > 3.5));
  io.print(bytes[2]);
  return 0;
}

# AST: VariableStat (id=matrix
# AST-SAME: type=Tensor<Float32>
# AST: CallExpr {{.*}}type=std_tensor_Tensor__Float32 callee=std.tensor.from
# AST: VariableExpr {{.*}}type=Array<Array<Float32, 2>, 2> name=values
# AST: VariableStat (id=bytes
# AST-SAME: type=Tensor<UInt64>
# AST: CallExpr {{.*}}type=std_tensor_Tensor__UInt64 callee=std.tensor.from
# AST: ArrayLiteralExpr {{.*}}type=Array<UInt64, 3>

# MLIR: mulberry_core.heap.alloc f32
# MLIR: mulberry_core.heap.alloc i64
# MLIR: mulberry_core.record.get_field {{.*}}["data"]
# MLIR: mulberry_core.ptr.index
# MLIR-NOT: call @std.tensor.from

# JIT: 4
# JIT-NEXT: 1
# JIT-NEXT: 30
