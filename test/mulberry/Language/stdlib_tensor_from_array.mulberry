# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var values =
      [[1.0, 2.0], [3.0, 4.0]];
  var matrix = tensor.from(values);
  var bytes = tensor.from([10, 20, 30]);

  io.println(matrix.numel());
  io.println(boolToUInt64(matrix[1, 1] > 3.5));
  io.println(bytes[2]);
  return 0;
}

# AST: VariableStat {{.*}}id=matrix{{.*}}inferredType=std.tensor.Tensor<Float32>
# AST: CallExpr {{.*}}type=std_tensor_Tensor__Float32 callee=std_tensor_from__Array_Array_Float32
# AST: VariableExpr {{.*}}type=Array<Array<Float32, 2>, 2> name=values
# AST: VariableStat {{.*}}id=bytes{{.*}}inferredType=std.tensor.Tensor<UInt64>
# AST: CallExpr {{.*}}type=std_tensor_Tensor__UInt64 callee=std_tensor_from__Array_UInt64
# AST: ArrayLiteralExpr {{.*}}type=Array<UInt64, 3>

# MLIR-LABEL: func.func @main()
# MLIR: call @std_tensor_from__Array_Array_Float32
# MLIR: call @std_tensor_from__Array_UInt64
# MLIR-NOT: call @std.tensor.from
# MLIR-LABEL: func.func @std_tensor_from__Array_Array_Float32
# MLIR: mulberry_core.heap.alloc f32
# MLIR: call @std_tensor_flattenInto__Array_Array_Float32
# MLIR-LABEL: func.func @std_tensor_from__Array_UInt64
# MLIR: mulberry_core.heap.alloc i64
# MLIR: call @std_tensor_flattenInto__Array_UInt64

# JIT: 4
# JIT-NEXT: 1
# JIT-NEXT: 30
