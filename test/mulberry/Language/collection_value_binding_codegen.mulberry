# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var w1 = tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var w2 = tensor.from([[5.0, 6.0]]);

  var weights: List<Tensor<Float32>> =
      list.withCapacity(1);
  weights.push(w1);
  weights = list.withCapacity(1);
  weights.push(w2);

  var activation = w1;
  activation = w2;

  return weights.size() + 1;
}

# CHECK-LABEL: func.func @main()
# CHECK: mulberry_core.heap.alloc f32
# CHECK: mulberry_core.record.get_field {{.*}}["data"]
# CHECK: call @std_list_withCapacity__
# CHECK: call @std_list_List_push__
# CHECK: call @std_list_List_size__
