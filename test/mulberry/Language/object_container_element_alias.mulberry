# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Counter {
  value: UInt64
}

fn main(): UInt64 {
  var arrayCounter = Counter { 1 };
  var counters = [arrayCounter];
  counters[0].value = 31;
  io.println(arrayCounter.value);

  var listCounter = Counter { 2 };
  var counterList = list.from([listCounter]);
  counterList[0].value = 32;
  io.println(listCounter.value);

  var value = tensor.from([3, 4]);
  var tensors = list.from([value]);
  tensors[0][1] = 33;
  io.println(value[1]);

  var tensorArray = [value];
  tensorArray[0][0] = 34;
  io.println(value[0]);
  return 0;
}

# JIT: 31
# JIT-NEXT: 32
# JIT-NEXT: 33
# JIT-NEXT: 34
