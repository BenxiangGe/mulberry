# RUN: mulberry-driver %s -dump=mlir 2>&1 | FileCheck %s

fn bar(x: UInt64, y: Bool): Bool {
  var k = y;

  if k {
    k = false;
  } else {
    k = true;
  }

  return k;
}

fn main(): UInt64 {
  bar(18446744073709551615, false);
  return 0;
}

# CHECK-LABEL: func.func @bar
# CHECK: scf.if
# CHECK: arith.constant false
# CHECK: arith.constant true
# CHECK: return {{.*}} : i1
# CHECK-LABEL: func.func @main
# CHECK: call @bar
# CHECK-NOT: cir.
