# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s

import safetensors;

fn main(): UInt64 {
  const file: File = io.open("data/mnist-784-30-10.safetensors", "rb");
  var w1: Tensor<Float32> = safetensors.readTensor(file, "w1");
  var b1: Tensor<Float32> = safetensors.readTensor(file, "b1");
  io.close(file);
  return 0;
}

# CHECK: CallExpr {{.*}}type=std_tensor_Tensor__Float32 callee=std.safetensors.readTensor
# CHECK: CallExpr {{.*}}type=std_tensor_Tensor__Float32 callee=std.safetensors.readTensor
