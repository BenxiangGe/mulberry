# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s

import safetensors;

fn run(): Result<UInt64, safetensors.SafetensorsError> {
  const file = safetensors.open("data/mnist-784-30-10.safetensors")?;
  var w1: Tensor<Float32> = safetensors.read(file, "w1")?;
  var b1: Tensor<Float32> = safetensors.read(file, "b1")?;
  safetensors.close(file)?;
  return Ok(0);
}

fn main(): UInt64 {
  return match run() {
    Ok(status) => status,
    Err(error) => 1,
  };
}

# CHECK: TryExpr {{.*}}type=std_tensor_Tensor__Float32
# CHECK-NEXT: CallExpr {{.*}}callee=std.safetensors.read
# CHECK: TryExpr {{.*}}type=std_tensor_Tensor__Float32
# CHECK-NEXT: CallExpr {{.*}}callee=std.safetensors.read
