# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var outputValues: Float32[4] = [1.0, 7.0, 3.0, 4.0];
  const output: File = io.open("/tmp/mulberry_file_tensor_io_jit.bin", "wb");
  const writeCount: UInt64 = io.write(output, tensor.pack(outputValues));
  io.close(output);

  var inputValues: Float32[4] = [0.0, 0.0, 0.0, 0.0];
  var inputTensor: Tensor<Float32> = tensor.pack(inputValues);
  const input: File = io.open("/tmp/mulberry_file_tensor_io_jit.bin", "rb");
  const readCount: UInt64 = io.read(input, inputTensor);
  io.close(input);
  var inputView: Float32[?] = tensor.view(inputTensor);

  io.print(writeCount);
  io.print(readCount);
  io.print(boolToUInt64(inputView[1] > 6.5));
  0
}

# JIT: 16
# JIT-NEXT: 16
# JIT-NEXT: 1
