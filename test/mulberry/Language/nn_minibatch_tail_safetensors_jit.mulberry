# RUN: %numpy_python %mulberry_src_root/tools/export_mnist_training_safetensors.py --sample-count 11 --test-count 10 --output /tmp/mulberry_nn_minibatch_tail_safetensors_jit.safetensors > %t.export.log && mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import mulberry.nn;
import safetensors;

fn main(): UInt64 {
  const file =
      safetensors.open("/tmp/mulberry_nn_minibatch_tail_safetensors_jit.safetensors");

  var w1 = safetensors.read(file, "w1");
  var b1 = safetensors.read(file, "b1");
  var w2 = safetensors.read(file, "w2");
  var b2 = safetensors.read(file, "b2");
  var trainX = safetensors.read(file, "train_x");
  var trainY = safetensors.read(file, "train_y");
  safetensors.close(file);

  var train = nn.datasetFromBatches(trainX, trainY);

  const eta = 0.1;
  const batchSize = 5;
  const trainingSize = train.size();
  const batchCount = nn.batchCount(trainingSize, batchSize);
  const lastBatchIndex = batchCount - 1;
  const lastBatchStart = lastBatchIndex * batchSize;
  const lastBatchEnd =
      nn.batchEnd(lastBatchStart, batchSize, trainingSize);
  const regularization = 0.01;
  const weightScale =
      nn.l2WeightScale(eta, regularization, trainingSize);
  var processedSamples = 0;

  train.shuffle(12345);
  for batch in 0 .. batchCount {
    const batchStart = batch * batchSize;
    const batchEnd = nn.batchEnd(batchStart, batchSize,
                                         trainingSize);
    const currentBatchSize = batchEnd - batchStart;
    const batchScale = eta / core.toFloat32(currentBatchSize);

    var sumW1: Tensor<Float32> = tensor.zeros([30, 784]);
    var sumB1: Tensor<Float32> = tensor.zeros([30, 1]);
    var sumW2: Tensor<Float32> = tensor.zeros([10, 30]);
    var sumB2: Tensor<Float32> = tensor.zeros([10, 1]);

    for sample in batchStart .. batchEnd {
      processedSamples = processedSamples + 1;
      const x = train.input(sample);
      const y = train.label(sample);
      var weights = list.from([w1, w2]);
      var biases = list.from([b1, b2]);
      const gradient =
          nn.twoLayerGradient(weights, biases, x, y);

      sumW1 = nn.matadd(sumW1, gradient.w1);
      sumB1 = nn.matadd(sumB1, gradient.b1);
      sumW2 = nn.matadd(sumW2, gradient.w2);
      sumB2 = nn.matadd(sumB2, gradient.b2);
    }

    w1 = nn.updateWeight(w1, sumW1, batchScale, weightScale);
    b1 = nn.matsub(b1, nn.matscale(sumB1, batchScale));
    w2 = nn.updateWeight(w2, sumW2, batchScale, weightScale);
    b2 = nn.matsub(b2, nn.matscale(sumB2, batchScale));
  }

  var finalWeights = list.from([w1, w2]);
  var finalBiases = list.from([b1, b2]);
  const evaluation =
      nn.evaluateDataset(finalWeights, finalBiases, train);

  io.println(trainingSize);
  io.println(batchCount);
  io.println(lastBatchEnd);
  io.println(processedSamples);
  io.println(evaluation.total);
  return 0;
}

