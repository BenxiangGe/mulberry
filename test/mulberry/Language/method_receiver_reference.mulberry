# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Counter {
  value: UInt64,

  pub fn bump(mut self: Counter): UInt64 {
    self.value = self.value + 1;
    return self.value;
  }
}

fn main(): UInt64 {
  var counter = Counter { 40 };
  counter.bump();
  counter.bump();
  io.println(counter.value);
  return 0;
}

# JIT: 42
