# JIT-NEXT: 20
# JIT-NEXT: 24
# JIT-NEXT: 12
# JIT-NEXT: 2880
# JIT-NEXT: 10
# JIT-NEXT: 8
# JIT-NEXT: 8
# JIT-NEXT: 1
# JIT-NEXT: 7
