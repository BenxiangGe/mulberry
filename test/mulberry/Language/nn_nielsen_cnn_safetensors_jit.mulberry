# RUN: %numpy_python %mulberry_src_root/tools/export_nielsen_cnn_safetensors.py --output /tmp/mulberry_nielsen_cnn_safetensors_jit.safetensors | FileCheck %s --check-prefix=EXPORT
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import mulberry.nn;
import safetensors;

fn main(): UInt64 {
  const file = safetensors.open(
      "/tmp/mulberry_nielsen_cnn_safetensors_jit.safetensors");

  var input = safetensors.read(file, "input");
  var convWeight =
      safetensors.read(file, "conv1_weight");
  var convBias = safetensors.read(file, "conv1_bias");
  var classifierWeight =
      safetensors.read(file, "classifier_weight");
  var classifierBias =
      safetensors.read(file, "classifier_bias");
  var reference =
      safetensors.read(file, "reference_probabilities");
  var label = safetensors.read(file, "label");
  safetensors.close(file);

  var convolved =
      nn.conv2d(input, convWeight, convBias);
  var pooled = nn.maxPool2d(convolved, 2, 2);
  var activated = nn.relu(pooled);
  var features = tensor.reshape(activated, [1, 2880]);
  var logits = nn.matadd(
      nn.matmul(features, classifierWeight), classifierBias);
  var probabilities = nn.softmax(logits);

  const prediction = nn.argmax(probabilities);
  const referencePrediction = nn.argmax(reference);
  io.println(input.ndim());
  io.println(convolved.dim(1));
  io.println(convolved.dim(2));
  io.println(pooled.dim(2));
  io.println(features.dim(1));
  io.println(probabilities.dim(1));
  io.println(prediction);
  io.println(referencePrediction);
  io.println(boolToUInt64(prediction == referencePrediction));
  io.println(nn.argmax(label));
  return 0;
}

# EXPORT: topology: NCHW conv -> 2x2 pool -> ReLU -> flatten -> softmax
# EXPORT: input: F32[1, 1, 28, 28]
# EXPORT: conv1_weight: F32[20, 1, 5, 5]
# EXPORT: classifier_weight: F32[2880, 10]
# EXPORT: reference prediction: 8
# EXPORT: MNIST label: 7
# EXPORT: parameters: deterministic fixture, not a trained Nielsen checkpoint

# JIT: 4
# JIT-NEXT: 20
# JIT-NEXT: 24
# JIT-NEXT: 12
# JIT-NEXT: 2880
# JIT-NEXT: 10
# JIT-NEXT: 8
# JIT-NEXT: 8
# JIT-NEXT: 1
# JIT-NEXT: 7
