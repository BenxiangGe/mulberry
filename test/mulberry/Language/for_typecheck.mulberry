# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var xs: UInt64[3] = [1, 2, 3];

  for i in 0 .. 3 {
    io.print(i);
  }

  return 0;
}

# CHECK: ArrayLiteralExpr {{.*}}type=Array<UInt64, 3>
# CHECK: ForStat
# CHECK-SAME: variable=i
# CHECK: bodyBlock:
# CHECK-NEXT: CallExpr
# CHECK-SAME: callee=std.io.print
# CHECK-NEXT: VariableExpr
# CHECK-SAME: type=UInt64
# CHECK-SAME: name=i
