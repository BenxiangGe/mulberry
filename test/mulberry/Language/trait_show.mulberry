# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Label {
  value: UInt64,

  pub fn toString(self: Label): String {
    return "Label({$self.value})";
  }
}

struct Plain {
  value: UInt64
}

data Choice = Number(UInt64) | Missing;

fn show<T: Show>(value: T): String {
  return value.toString();
}

fn main(): UInt64 {
  io.println(show(7));
  io.println(show(Label { 11 }));
  io.println(show(Plain { 13 }));
  const choice: Choice = Number(17);
  io.println(show(choice));
  return 0;
}

# AST-DAG: Prototype {{.*}}name=show parameter=T: Show
# AST-DAG: CallExpr {{.*}}callee=show__UInt64
# AST-DAG: CallExpr {{.*}}callee=show__Label
# AST-DAG: CallExpr {{.*}}callee=show__Plain
# AST-DAG: CallExpr {{.*}}callee=show__Choice
# AST-DAG: CallExpr {{.*}}callee=std.string.Show__UInt64.toString
# AST-DAG: CallExpr {{.*}}callee=Label.toString
# AST-DAG: CallExpr {{.*}}callee=std_string_objectToString__Plain
# AST-DAG: CallExpr {{.*}}callee=std_string_objectToString__Choice

# MLIR-DAG: func.func @show__UInt64
# MLIR-DAG: call @std.string.Show__UInt64.toString
# MLIR-DAG: func.func @show__Label
# MLIR-DAG: call @Label.toString
# MLIR-DAG: func.func @show__Plain
# MLIR-DAG: call @std_string_objectToString__Plain
# MLIR-DAG: func.func @show__Choice
# MLIR-DAG: call @std_string_objectToString__Choice

# JIT: 7
# JIT-NEXT: Label(11)
# JIT-NEXT: Plain@0x{{[0-9a-f]+}}
# JIT-NEXT: Choice@0x{{[0-9a-f]+}}
