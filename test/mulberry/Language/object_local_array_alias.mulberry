# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver %s 2>&1 | FileCheck %s

fn id(xs: UInt64[3]): UInt64[3] {
  return xs;
}

fn main(): UInt64 {
  var a: UInt64[3] = [1, 2, 3];
  var b: UInt64[3] = a;
  b[1] = 40;

  var c: UInt64[3] = id(a);
  c[2] = 50;

  io.print(a[0] + a[1] + a[2]);

  a = [4, 5, 6];
  io.print(b[0] + b[1] + b[2]);
  io.print(a[0] + a[1] + a[2]);
  return 0;
}

# CHECK: 91
# CHECK-NEXT: 91
# CHECK-NEXT: 15
