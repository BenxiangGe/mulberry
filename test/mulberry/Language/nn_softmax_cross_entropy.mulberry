# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import mulberry.nn;

fn main(): UInt64 {
  var logits = tensor.from([
    [1000.0, 1000.0],
    [0.0, 0.0]
  ]);
  var expected = tensor.from([
    [1.0, 0.0],
    [0.0, 1.0]
  ]);
  const loss = nn.softmaxCrossEntropy(logits, expected);

  var matches = 0;
  if loss > 0.693 and loss < 0.694 {
    matches = 1;
  }
  io.print(matches);
  return 0;
}

# LOWERED: arith.maximumf
# LOWERED: math.exp
# LOWERED: math.log
# LOWERED: arith.divf
# LOWERED-NOT: mulberry_nn.

# JIT: 1
