# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s

import json;
import tensor;
import tensor.Tensor;
import io;

fn main(): UInt64 {
  var text: Tensor<UInt8> = tensor.from([
      '{', '"', 'a', '"', ':', '[', '1', '2', ',', '3', '4', ']', ',',
      '"', 'b', '"', ':', '{', '"', 'c', '"', ':', '5', '}', '}'
  ]);
  var parser = json.Parser { text, 0, 25 };
  parser.consumeChar('{');
  io.print(boolToUInt64(parser.stringEquals("a")));
  parser.consumeChar(':');
  var values = parser.parseIntegerArray();
  io.print(values.size());
  io.print(values[0]);
  io.print(values[1]);
  parser.consumeChar(',');
  io.print(boolToUInt64(parser.stringEquals("b")));
  parser.consumeChar(':');
  parser.skipValue();
  io.print(parser.position);
  return 0;
}

# MLIR-LABEL: func.func @std.json.Parser.peekChar
# MLIR: mulberry_core.ptr.index
# MLIR-LABEL: func.func @std.json.Parser.isDigit

# CHECK: 1
# CHECK-NEXT: 2
# CHECK-NEXT: 12
# CHECK-NEXT: 34
# CHECK-NEXT: 1
# CHECK-NEXT: 24
