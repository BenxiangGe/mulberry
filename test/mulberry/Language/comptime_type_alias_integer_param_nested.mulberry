# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

comptime Storage<T, Rank: UInt64> = struct {
  value: T,
  rank: UInt64
};

comptime Handle<T, Rank: UInt64> = Storage<T, Rank>;

fn main(): UInt64 {
  var handle = Storage<Float32, 2> { 1.5, 2 };
  return handle.rank;
}

# MLIR-LABEL: func.func @main()
# MLIR: !mulberry_core.record<Storage__Float32__2
# MLIR: mulberry_core.record.get_field {{.*}}["rank"]
