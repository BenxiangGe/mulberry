# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var t: Float32[2] = [1.25, 2.5];
  t[1] = 3.5;

  var tensor: Float32[2, 2] = [[1.0, 2.0], [3.0, 4.0]];
  tensor[1, 0] = t[0];

  0
}

# CHECK: mulberry.tensor.alloc() : !mulberry.tensor<2xf32>
# CHECK: arith.constant {{.*}} : f32
# CHECK: mulberry.tensor.store
# CHECK-SAME: !mulberry.tensor<2xf32>
# CHECK: arith.constant {{.*}} : f32
# CHECK: mulberry.tensor.store
# CHECK-SAME: !mulberry.tensor<2xf32>
# CHECK: mulberry.tensor.alloc() : !mulberry.tensor<2x2xf32>
# CHECK: mulberry.tensor.load
# CHECK-SAME: !mulberry.tensor<2xf32>
# CHECK: mulberry.tensor.store
# CHECK-SAME: !mulberry.tensor<2x2xf32>
# CHECK-NOT: memref.
