# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var value: UInt64 = 3;
  var keepGoing: Bool = true;
  io.print(value);

  while keepGoing {
    var value: UInt64 = 4;
    io.print(value);
    keepGoing = false;
  }

  io.print(value);
  0
}

# CHECK-LABEL: func.func @main
# CHECK: %[[OUTER:.*]] = mulberry.alloca i64 : !mulberry.ptr<i64>
# CHECK: arith.constant 3 : i64
# CHECK: mulberry.store {{.*}}, %[[OUTER]] : i64, !mulberry.ptr<i64>
# CHECK: %[[TRUE:.*]] = arith.constant true
# CHECK: mulberry.store %[[TRUE]], %[[KEEP_GOING:.*]] : i1, !mulberry.ptr<i1>
# CHECK: scf.while
# CHECK: %[[INNER:.*]] = mulberry.alloca i64 : !mulberry.ptr<i64>
# CHECK: arith.constant 4 : i64
# CHECK: mulberry.store {{.*}}, %[[INNER]] : i64, !mulberry.ptr<i64>
# CHECK: mulberry.store {{.*}}, %[[KEEP_GOING]] : i1, !mulberry.ptr<i1>
# CHECK: mulberry.load %[[OUTER]] : !mulberry.ptr<i64> -> i64
# CHECK-NOT: cir.
