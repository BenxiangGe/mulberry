# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn run(): Result<UInt64, io.FileError> {
  var outputBytes: Tensor<UInt8> = tensor.from([10, 20, 30, 40]);
  const output = io.open("/tmp/mulberry_file_api_jit.bin", "wb")?;
  io.write(output, outputBytes)?;
  const outputPosition = io.tell(output)?;
  io.close(output)?;

  var inputTensor: Tensor<UInt8> = tensor.zeros([4]);
  const input = io.open("/tmp/mulberry_file_api_jit.bin", "rb")?;
  io.seek(input, 0)?;
  const count = io.read(input, inputTensor)?;
  io.close(input)?;

  io.println(outputPosition);
  io.println(count);
  io.println(boolToUInt64(inputTensor[0] == outputBytes[0]));
  io.println(boolToUInt64(inputTensor[1] == outputBytes[1]));
  io.println(boolToUInt64(inputTensor[2] == outputBytes[2]));
  io.println(boolToUInt64(inputTensor[3] == outputBytes[3]));
  return Ok(0);
}

fn main(): UInt64 {
  return match run() {
    Ok(status) => status,
    Err(error) => 1,
  };
}

# JIT: 4
# JIT-NEXT: 4
# JIT-NEXT: 1
# JIT-NEXT: 1
# JIT-NEXT: 1
# JIT-NEXT: 1
