# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import list;
import list.List;
import io;
import tensor;
import tensor.Tensor;

fn first(xs: List<Tensor<Float32>>): Tensor<Float32> {
  xs[0]
}

fn main(): UInt64 {
  var w1: Tensor<Float32> = tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var w2: Tensor<Float32> = tensor.from([[5.0, 6.0]]);
  var xs: List<Tensor<Float32>> = list.from([w1, w2]);

  io.print(xs.size());
  io.print(first(xs).numel());
  0
}

# MLIR-LABEL: func.func @first
# MLIR-SAME: !mulberry_core.record<std_list_List__
# MLIR-SAME: -> !mulberry_core.record<std_tensor_Tensor__Float32
# MLIR: call @std_list_List_get__
# MLIR-LABEL: func.func @main
# MLIR: mulberry_core.heap.alloc f32
# MLIR: mulberry_core.record.get_field {{.*}}["data"]
# MLIR: call @std_list_from__std_tensor_Tensor__Float32__2
# MLIR: call @std_list_List_size__
# MLIR: call @first
# MLIR: call @std_tensor_Tensor_numel__Float32
# MLIR: call @std.io.print

# LOWER-LABEL: func.func @first
# LOWER-SAME: -> !llvm.struct
# LOWER: call @std_list_List_get__
# LOWER-LABEL: func.func @main
# LOWER: call @std_list_from__std_tensor_Tensor__Float32__2
# LOWER: call @std_list_List_size__
# LOWER: call @first
# LOWER: call @std.io.print

# JIT: 2
# JIT-NEXT: 4
