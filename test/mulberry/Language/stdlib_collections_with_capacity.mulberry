# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var xs: List<UInt64> = list.withCapacity(2);
  xs.length = 2;
  xs[0] = 42;
  xs[1] = 58;
  io.print(xs.size());
  io.print(xs[0] + xs[1]);
  return 0;
}

# AST: CallExpr {{.*}}callee=std_list_withCapacity__UInt64
# AST-DAG: IndexExpr {{.*}}type=UInt64 kind=stdlibList

# MLIR-LABEL: func.func @main()
# MLIR: call @std_list_withCapacity__UInt64
# MLIR-DAG: func.func @std_list_withCapacity__UInt64
# MLIR-DAG: mulberry_core.heap.alloc i64

# JIT: 2
# JIT-NEXT: 100
