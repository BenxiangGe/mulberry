# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

comptime RankedBox<T, Rank: UInt64> = struct {
  value: T,

  pub fn get(self: RankedBox<T, Rank>): T {
    return self.value;
  }
};

fn main(): UInt64 {
  var box: RankedBox<UInt64, 2> = RankedBox<UInt64, 2> { 42 };
  io.print(box.get());
  return 0;
}

# AST: ComptimeTypeAliasDecl {{.*}}name=RankedBox parameter=T, Rank: UInt64 type=struct {value: T, fn RankedBox.get}
# AST: CallExpr {{.*}}callee=RankedBox_get__UInt64__2
# AST: Prototype {{.*}}name=RankedBox_get__UInt64__2

# JIT: 42
