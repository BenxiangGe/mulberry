# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import mulberry.nn;

fn main(): UInt64 {
  var left = tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var right = tensor.from([[0.25], [0.5]]);
  var bias = tensor.from([[0.0], [0.0]]);

  var product = nn.matmul(left, right);
  var shifted = nn.matadd(product, bias);
  var activated = nn.sigmoid(shifted);
  io.println(nn.argmax(activated));

  var restored = nn.matsub(shifted, bias);
  var squared = nn.hadamard(restored, product);
  io.println(nn.argmax(squared));

  var transposed = nn.transpose(right);
  var scaled = nn.matscale(transposed, 2.0);
  var exponentials = nn.exp(scaled);
  io.println(nn.argmax(exponentials));

  var primeInput = tensor.from([[0.0], [1.0]]);
  var prime = nn.sigmoidPrime(primeInput);
  io.println(nn.argmax(prime));

  return 0;
}

# JIT: 1
# JIT-NEXT: 1
# JIT-NEXT: 1
# JIT-NEXT: 0
