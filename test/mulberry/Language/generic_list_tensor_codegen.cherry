# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn first(weights: List<Tensor<Float32>>): Tensor<Float32> {
  weights[0]
}

fn make(): List<Tensor<Float32>> {
  var w1: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var w2: Float32[?, ?] = [[5.0, 6.0]];
  var w1h: Tensor<Float32> = tensor.pack(w1);
  var w2h: Tensor<Float32> = tensor.pack(w2);
  var weights: List<Tensor<Float32>> = [w1h, w2h];
  weights
}

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var w2: Float32[?, ?] = [[5.0, 6.0]];
  var w1h: Tensor<Float32> = tensor.pack(w1);
  var w2h: Tensor<Float32> = tensor.pack(w2);
  var weights: List<Tensor<Float32>> = [w1h, w2h];
  const layer: Tensor<Float32> = first(weights);
  layer.numel() + make().size()
}

# CHECK-LABEL: func.func @first(%arg0: !mulberry.record<std_collections_List__
# CHECK-SAME: -> !mulberry.record<std_tensor_Tensor__Float32
# CHECK: call @std_collections_List_get__
# CHECK-LABEL: func.func @make()
# CHECK-SAME: -> !mulberry.record<std_collections_List__
# CHECK: mulberry.tensor.alloc
# CHECK: mulberry.tensor.alloc
# CHECK: mulberry.tensor.pack
# CHECK: call @std_collections_withCapacity__
# CHECK: call @std_collections_List_push__
# CHECK-LABEL: func.func @main()
# CHECK: call @std_collections_withCapacity__
# CHECK: call @std_collections_List_push__
# CHECK: call @first
# CHECK: call @std_tensor_Tensor_numel__Float32
# CHECK: call @make
# CHECK: call @std_collections_List_size__
