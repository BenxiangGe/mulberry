# RUN: %numpy_python %mulberry_src_root/tools/export_mnist_safetensors.py --output /tmp/mulberry_safetensors_read_tensor_jit.safetensors > %t.export.log && mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import safetensors;

fn main(): UInt64 {
  const file =
      io.open("/tmp/mulberry_safetensors_read_tensor_jit.safetensors", "rb");
  var x = safetensors.readTensor(file, "x");
  var w1 = safetensors.readTensor(file, "w1");
  io.close(file);

  io.println(x.numel());
  io.println(x.ndim());
  io.println(x.dim(0));
  io.println(x.dim(1));
  io.println(x.stride(0));
  io.println(x.stride(1));
  io.println(w1.numel());
  io.println(w1.ndim());
  io.println(w1.dim(0));
  io.println(w1.dim(1));
  io.println(w1.stride(0));
  io.println(w1.stride(1));
  return 0;
}

