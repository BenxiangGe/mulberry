# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

comptime RankedBox<T, Rank: UInt64> = struct {
  value: T
};

fn main(): UInt64 {
  var box: RankedBox<UInt64, 2> = RankedBox<UInt64, 2> { 42 };
  io.println(box.value);
  return 0;
}

# AST: ComptimeTypeAliasDecl {{.*}}name=RankedBox parameter=T, Rank: UInt64 type=struct {value: T}
# AST: VariableStat (id=box
# AST-SAME: type=RankedBox<UInt64, 2>

# MLIR-LABEL: func.func @main()
# MLIR: mulberry_core.record.get_field {{.*}}["value"]
