# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var xs: List<UInt64> = list.from([10, 20, 30, 40]);
  var ys: List<UInt64> = list.from([1, 2, 3, 4]);

  list.shufflePair(xs, ys, 123);

  io.print(xs.size());
  io.print(ys.size());
  io.print(xs[0] + ys[0] * 100);
  io.print(xs[1] + ys[1] * 100);
  io.print(xs[2] + ys[2] * 100);
  io.print(xs[3] + ys[3] * 100);
  0
}

