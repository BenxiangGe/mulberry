# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var xs = list.from([10, 20, 30, 40]);
  var ys = list.from([1, 2, 3, 4]);

  list.shufflePair(xs, ys, 123);

  io.println(xs.size());
  io.println(ys.size());
  io.println(xs[0] + ys[0] * 100);
  io.println(xs[1] + ys[1] * 100);
  io.println(xs[2] + ys[2] * 100);
  io.println(xs[3] + ys[3] * 100);
  return 0;
}

# JIT: 4
# JIT-NEXT: 4
# JIT-NEXT: 220
# JIT-NEXT: 440
# JIT-NEXT: 330
# JIT-NEXT: 110
