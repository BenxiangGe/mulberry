# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

package std.imports;

import collections;
import collections.List;

fn id(xs: List<UInt64>): List<UInt64> {
  xs
}

fn main(): UInt64 {
  var xs: collections.List<UInt64> = collections.withCapacity(1);
  id(xs).length
}

# AST: ComptimeTypeAliasDecl {{.*}}(name=std.collections.List parameter=T
# AST: FunctionDecl {{.*}}
# AST: Prototype {{.*}}name=std.imports.id
# AST: VariableStat {{.*}}id=xs{{.*}}type=List<UInt64>
# AST: Body:
# AST: VariableExpr {{.*}}name=xs
# AST: FunctionDecl {{.*}}
# AST: Prototype {{.*}}name=std.imports.main
# AST: VariableStat {{.*}}id=xs{{.*}}type=collections.List<UInt64>
# AST: CallExpr {{.*}}callee=std_collections_withCapacity__UInt64
# AST: MemberExpr {{.*}}field=length
# AST: CallExpr {{.*}}callee=std.imports.id
# MLIR-LABEL: func.func @std.imports.id(%arg0: !mulberry.record<std_collections_List__UInt64
# MLIR-SAME: -> !mulberry.record<std_collections_List__UInt64
# MLIR: call @std.imports.id
