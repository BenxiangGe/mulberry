# AST: FunctionDecl {{.*}}
# AST: Prototype {{.*}}name=std.imports.id
# AST: VariableStat {{.*}}id=xs{{.*}}type=List<UInt64>
# AST: Body:
# AST: VariableExpr {{.*}}name=xs
# AST: FunctionDecl {{.*}}
# AST: Prototype {{.*}}name=std.imports.main
# AST: VariableStat {{.*}}id=xs{{.*}}type=collections.List<UInt64>
# AST: CallExpr {{.*}}callee=std_list_withCapacity__UInt64
# AST: MemberExpr {{.*}}field=length
# AST: CallExpr {{.*}}callee=std.imports.id
# MLIR-LABEL: func.func @std.imports.id(%arg0: !mulberry_core.ptr<!mulberry_core.record<std_list_List__UInt64
# MLIR-SAME: -> !mulberry_core.ptr<!mulberry_core.record<std_list_List__UInt64
# MLIR: call @std_list_withCapacity__UInt64
