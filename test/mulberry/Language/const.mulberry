# RUN: mulberry-driver -dump=tokens %s 2>&1 | FileCheck %s --check-prefix=TOKENS
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

fn main(): UInt64 {
  const answer: UInt64 = 42;
  const tensorValue: Tensor<Float32> =
      tensor.from([[1.0, 2.0], [3.0, 4.0]]);

  return answer + tensorValue.numel();
}

# TOKENS: kw_const 'const'
# TOKENS: kw_const 'const'

# AST: Prototype {{.*}}name=main
# AST: VariableStat const (id=answer
# AST: VariableStat const (id=tensorValue

# MLIR: arith.constant 42 : i64
# MLIR: mulberry_core.heap.alloc f32
# MLIR: mulberry_core.record.get_field {{.*}}["numel"]
# MLIR: call @std_tensor_Tensor_numel__Float32
# MLIR-NOT: cir.
