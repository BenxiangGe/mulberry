# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct Pair {
  x: UInt64,
  y: UInt64
}

fn makePair(x: UInt64): Pair {
  Pair { x, x + 1 }
}

fn main(): UInt64 {
  makePair(41).y
}

# CHECK-LABEL: func.func @main
# CHECK: call @makePair
# CHECK: mulberry_core.record.extract {{.*}}["y"] : !mulberry_core.record<Pair {x: i64, y: i64}> -> i64
