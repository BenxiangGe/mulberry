# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

fn sum(values: UInt64[3]): UInt64 {
  return values[0] + values[1] + values[2];
}

fn main(): UInt64 {
  const values: UInt64[3] = [1, 2, 3];
  return sum(values);
}

# AST: Prototype {{.*}}name=sum
# AST: VariableStat {{.*}}id=values{{.*}}type=UInt64[3]
# MLIR-LABEL: func.func @sum
# MLIR: return
