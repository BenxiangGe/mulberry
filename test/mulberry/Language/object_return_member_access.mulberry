# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct Pair {
  x: UInt64,
  y: UInt64
}

fn makePair(x: UInt64): Pair {
  return Pair { x, x + 1 };
}

fn main(): UInt64 {
  return makePair(41).y;
}

# CHECK-LABEL: func.func @main
# CHECK: call @makePair
# CHECK: mulberry_core.record.get_field {{.*}}["y"] : !mulberry_core.ptr<!mulberry_core.record<Pair
# CHECK: mulberry_core.load {{.*}} : !mulberry_core.ptr<i64> -> i64
