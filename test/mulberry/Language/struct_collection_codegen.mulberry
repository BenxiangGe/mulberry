# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct Model {
  weights: List<Tensor<Float32>>,
  bias: Tensor<Float32>
}

fn makeModel(w1: Tensor<Float32>,
             w2: Tensor<Float32>,
             bias: Tensor<Float32>): Model {
  var weights: List<Tensor<Float32>> = list.from([w1, w2]);
  Model { weights, bias }
}

fn main(): UInt64 {
  var w1: Tensor<Float32> = tensor.from([[1.0, 0.0], [0.0, 1.0]]);
  var w2: Tensor<Float32> = tensor.from([[1.0, 1.0]]);
  var bias: Tensor<Float32> = tensor.from([[0.0]]);

  var model: Model = makeModel(w1, w2, bias);
  var otherBias: Tensor<Float32> = bias;
  var activeBias: Tensor<Float32> = if true {
    model.bias
  } else {
    otherBias
  };
  var firstWeight: Tensor<Float32> =
      model.weights[0];

  model.weights.size() + firstWeight.numel() + 1
}

# CHECK-LABEL: func.func @makeModel
# CHECK-SAME: !mulberry_core.record<std_tensor_Tensor__Float32
# CHECK-SAME: !mulberry_core.record<std_tensor_Tensor__Float32
# CHECK-SAME: !mulberry_core.record<std_tensor_Tensor__Float32
# CHECK-SAME: -> !mulberry_core.record<Model
# CHECK: call @std_list_from__std_tensor_Tensor__Float32__2
# CHECK: mulberry_core.record.get_field {{.*}}["bias"]
# CHECK-LABEL: func.func @main()
# CHECK: mulberry_core.heap.alloc f32
# CHECK: mulberry_core.record.get_field {{.*}}["data"]
# CHECK: call @makeModel
# CHECK: scf.if
# CHECK: mulberry_core.record.get_field {{.*}}["bias"]
# CHECK: mulberry_core.record.get_field {{.*}}["weights"]
# CHECK: call @std_list_List_get__
# CHECK: call @std_list_List_size__
# CHECK: call @std_tensor_Tensor_numel__Float32
