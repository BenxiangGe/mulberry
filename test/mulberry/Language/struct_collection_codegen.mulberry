# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct Model {
  weights: List<Tensor<Float32>>,
  bias: Tensor<Float32>
}

fn makeModel(w1: Tensor<Float32>,
             w2: Tensor<Float32>,
             bias: Tensor<Float32>): Model {
  var weights = list.from([w1, w2]);
  return Model { weights, bias };
}

fn main(): UInt64 {
  var w1 = tensor.from([[1.0, 0.0], [0.0, 1.0]]);
  var w2 = tensor.from([[1.0, 1.0]]);
  var bias = tensor.from([[0.0]]);

  var model = makeModel(w1, w2, bias);
  var otherBias = bias;
  var activeBias = otherBias;
  if true {
    activeBias = model.bias;
  } else {
    activeBias = otherBias;
  }
  var firstWeight =
      model.weights[0];

  return model.weights.size() + firstWeight.numel() + 1;
}

# CHECK-LABEL: func.func @makeModel
# CHECK-SAME: !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# CHECK-SAME: !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# CHECK-SAME: !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# CHECK-SAME: -> !mulberry_core.ptr<!mulberry_core.record<Model
# CHECK: call @std_list_from__std_tensor_Tensor__Float32__2
# CHECK: mulberry_core.record.get_field {{.*}}["bias"]
# CHECK-LABEL: func.func @main()
# CHECK: mulberry_core.heap.alloc f32
# CHECK: mulberry_core.record.get_field {{.*}}["data"]
# CHECK: call @makeModel
# CHECK: scf.if
# CHECK: mulberry_core.record.get_field {{.*}}["bias"]
# CHECK: mulberry_core.record.get_field {{.*}}["weights"]
# CHECK: call @std_list_List_get__
# CHECK: call @std_list_List_size__
# CHECK: call @std_tensor_Tensor_numel__Float32
