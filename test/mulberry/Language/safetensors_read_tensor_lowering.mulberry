# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED

import safetensors;

fn run(): Result<UInt64, safetensors.SafetensorsError> {
  const file = safetensors.open("data/mnist-784-30-10.safetensors")?;
  var w1Tensor = safetensors.read(file, "w1")?;
  safetensors.close(file)?;
  return Ok(w1Tensor.numel());
}

fn main(): UInt64 {
  return match run() {
    Ok(status) => status,
    Err(error) => 1,
  };
}

# MLIR: call @std.safetensors.read

# LOWERED-NOT: mulberry_safetensor_read_tensor_f32
# LOWERED-LABEL: func.func @std.safetensors.read(
# LOWERED: call @std.safetensors.find
# LOWERED: call @std_io_readExact__Float32
