# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

comptime Pair<T, U> = struct {
  first: T,
  second: U
};

fn main(): UInt64 {
  var pair: Pair<UInt64, Float32> = Pair<UInt64, Float32> { 42, 1.5 };
  io.println(pair.first);
  return 0;
}

# AST: ComptimeTypeAliasDecl {{.*}}name=Pair parameter=T, U type=struct {first: T, second: U}
# AST: VariableStat (id=pair
# AST-SAME: type=Pair<UInt64, Float32>

# MLIR-LABEL: func.func @main()
# MLIR: mulberry_core.record.get_field {{.*}}["first"]
