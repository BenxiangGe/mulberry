# RUN: mulberry-driver %s 2>&1 | FileCheck %s

import core;
import io;

fn id(value: Char): Char {
  return value;
}

fn main(): UInt64 {
  io.println(core.toUInt64(id('A')));
  io.println(core.toUInt64('\n'));
  io.println(core.toUInt64('\t'));
  io.println(core.toUInt64('\''));
  io.println(core.toUInt64('"'));
  io.println(core.toUInt64('\\'));
  return 0;
}

# CHECK: 65
# CHECK-NEXT: 10
# CHECK-NEXT: 9
# CHECK-NEXT: 39
# CHECK-NEXT: 34
# CHECK-NEXT: 92
