# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import mulberry.nn;

fn main(): UInt64 {
  var w1 = tensor.from([[1.0, 0.0], [0.0, 1.0]]);
  var w2 = tensor.from([[1.0, 0.0], [0.0, 1.0]]);
  var b1 = tensor.from([[0.0], [0.0]]);
  var b2 = tensor.from([[0.0], [0.0]]);

  var x0 = tensor.from([[1.0], [0.0]]);
  var x1 = tensor.from([[0.0], [1.0]]);
  var y0 = tensor.from([[1.0], [0.0]]);
  var y1 = tensor.from([[0.0], [1.0]]);
  var xs = list.from([x0, x1]);
  var ys = list.from([y0, y1]);
  var dataset = nn.datasetFromLists(xs, ys);
  const eta = 0.8;
  const batchSize = dataset.size();
  const batchScale = eta / core.toFloat32(batchSize);
  const regularization = 0.01;
  const weightScale =
      nn.l2WeightScale(eta, regularization, batchSize);

  for epoch in 0 .. 8 {
    var sumW1: Tensor<Float32> = tensor.zeros([2, 2]);
    var sumB1: Tensor<Float32> = tensor.zeros([2, 1]);
    var sumW2: Tensor<Float32> = tensor.zeros([2, 2]);
    var sumB2: Tensor<Float32> = tensor.zeros([2, 1]);

    for sample in 0 .. batchSize {
      const x = dataset.input(sample);
      const y = dataset.label(sample);
      var weights = list.from([w1, w2]);
      var biases = list.from([b1, b2]);
      const gradient =
          nn.twoLayerGradient(weights, biases, x, y);

      sumW1 = nn.matadd(sumW1, gradient.w1);
      sumB1 = nn.matadd(sumB1, gradient.b1);
      sumW2 = nn.matadd(sumW2, gradient.w2);
      sumB2 = nn.matadd(sumB2, gradient.b2);
    }

    w1 = nn.updateWeight(w1, sumW1, batchScale, weightScale);
    b1 = nn.matsub(b1, nn.matscale(sumB1, batchScale));
    w2 = nn.updateWeight(w2, sumW2, batchScale, weightScale);
    b2 = nn.matsub(b2, nn.matscale(sumB2, batchScale));
  }

  var finalWeights = list.from([w1, w2]);
  var finalBiases = list.from([b1, b2]);
  const evaluation =
      nn.evaluateDataset(finalWeights, finalBiases, dataset);

  io.println(nn.predict(finalWeights, finalBiases, dataset.input(0)));
  io.println(nn.predict(finalWeights, finalBiases, dataset.input(1)));
  io.println(evaluation.correct);

  return 0;
}

# JIT: 0
# JIT-NEXT: 1
# JIT-NEXT: 2
