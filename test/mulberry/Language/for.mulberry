# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var xs: UInt64[3] = [1, 2, 3];
  var sum: UInt64 = 0;

  for i in 0 .. 3 {
    sum = sum + xs[i];
  }

  io.print(sum);
  return 0;
}

# CHECK: !mulberry_core.record<array {length: i64, data: !mulberry_core.ptr<i64>}>
# CHECK: mulberry_core.heap.alloc i64
# CHECK: arith.constant 3 : i64
# CHECK: scf.for unsigned
# CHECK: mulberry_core.record.get_field {{.*}}["data"]
# CHECK: mulberry_core.ptr.index
# CHECK: mulberry_core.load
# CHECK: arith.addi
# CHECK-NOT: cir.
