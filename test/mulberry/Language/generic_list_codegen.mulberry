# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s
# RUN: mulberry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER

fn first(xs: List<UInt64>): UInt64 {
  return xs[0];
}

fn make(): List<UInt64> {
  var numbers = list.from([1, 2, 3]);
  return numbers;
}

fn main(): UInt64 {
  var numbers = list.from([4, 5, 6]);
  io.print(first(numbers));
  return make().size();
}

# CHECK-LABEL: func.func @first(%arg0: !mulberry_core.ptr<!mulberry_core.record<std_list_List__UInt64
# CHECK-SAME: -> i64
# CHECK: call @std_list_List_get__UInt64
# CHECK-LABEL: func.func @make()
# CHECK-SAME: -> !mulberry_core.ptr<!mulberry_core.record<std_list_List__UInt64
# CHECK: call @std_list_from__UInt64__3
# CHECK-LABEL: func.func @main()
# CHECK: call @std_list_from__UInt64__3
# CHECK: call @first
# CHECK: call @make
# CHECK: call @std_list_List_size__UInt64

# LOWER-DAG: llvm.func @mulberry_boehm_malloc(i64) -> !llvm.ptr
# LOWER-LABEL: func.func @first(%arg0: !llvm.ptr) -> i64
# LOWER: call @std_list_List_get__UInt64
# LOWER-LABEL: func.func @make
# LOWER-SAME: -> !llvm.ptr
# LOWER: call @std_list_from__UInt64__3
# LOWER-LABEL: func.func @main
# LOWER: call @std_list_from__UInt64__3
# LOWER: call @first
# LOWER: call @make
# LOWER: call @std_list_List_size__UInt64
# LOWER-NOT: llvm.call @free
