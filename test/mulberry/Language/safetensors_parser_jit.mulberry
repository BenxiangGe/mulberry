# RUN: %numpy_python %mulberry_src_root/tools/export_mnist_safetensors.py --output /tmp/mulberry_safetensors_parser_jit.safetensors > %t.export.log && mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import safetensors;

fn main(): UInt64 {
  const file: File =
      io.open("/tmp/mulberry_safetensors_parser_jit.safetensors", "rb");
  const w1: safetensors.TensorInfo = safetensors.findTensor(file, "w1");
  const x: safetensors.TensorInfo = safetensors.findTensor(file, "x");
  io.print(boolToUInt64(w1.found));
  io.print(w1.headerLength);
  io.print(w1.shape.size());
  io.print(w1.shape[0]);
  io.print(w1.shape[1]);
  io.print(w1.begin);
  io.print(w1.end);
  io.print(boolToUInt64(x.found));
  io.print(x.shape[0]);
  io.print(x.shape[1]);
  io.print(x.begin);
  io.print(x.end);
  io.close(file);
  return 0;
}

