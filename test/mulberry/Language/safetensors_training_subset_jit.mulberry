# RUN: %numpy_python %mulberry_src_root/tools/export_mnist_training_safetensors.py --sample-count 1 --test-count 2 --output /tmp/mulberry_safetensors_training_subset_jit.safetensors > %t.export.log && mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import mulberry.nn;
import safetensors;

fn main(): UInt64 {
  const file =
      safetensors.open("/tmp/mulberry_safetensors_training_subset_jit.safetensors");

  var trainX = safetensors.read(file, "train_x");
  var trainY = safetensors.read(file, "train_y");
  var testX = safetensors.read(file, "test_x");
  var testY = safetensors.read(file, "test_y");
  safetensors.close(file);

  var train = nn.datasetFromBatches(trainX, trainY);
  var test = nn.datasetFromBatches(testX, testY);

  var trainX0 = train.input(0);
  var trainY0 = train.label(0);
  var testX0 = test.input(0);
  var testY0 = test.label(0);
  var testY1 = test.label(1);

  io.println(trainX0.numel());
  io.println(testX0.numel());
  io.println(nn.argmax(trainY0));
  io.println(nn.argmax(testY0));
  io.println(nn.argmax(testY1));
  return 0;
}

