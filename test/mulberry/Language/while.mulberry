# RUN: mulberry-driver %s -dump=mlir 2>&1 | FileCheck %s

fn bar(y: Bool): Bool {
  var k = y;

  while k {
    k = false;
  }

  return k;
}

fn main(): UInt64 {
  bar(true);
  return 0;
}

# CHECK-LABEL: func.func @bar
# CHECK: scf.while
# CHECK: scf.condition
# CHECK: arith.constant false
# CHECK: return {{.*}} : i1
# CHECK-LABEL: func.func @main
# CHECK: call @bar
# CHECK-NOT: cir.
