# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn releaseSharedStorage(): () {
  var value: Tensor<UInt8> = tensor.zeros([4]);
  var alias = value;
  var view = tensor.reshape(value, [4]);
  io.println(value.numel());
  value.dispose();
  alias.dispose();
  view.dispose();
  return;
}

fn releaseAtLoopScope(): () {
  for index in 0 .. 8 {
    var value: Tensor<UInt8> = tensor.zeros([1024]);
    value[0] = core.toUInt8(index);
  }
  return;
}

fn releaseFromAtLoopScope(): () {
  for index in 0 .. 8 {
    var value: Tensor<UInt8> = tensor.from([1, 2, 3, 4]);
    value[0] = core.toUInt8(index);
  }
  return;
}

fn main(): UInt64 {
  releaseSharedStorage();
  releaseAtLoopScope();
  releaseFromAtLoopScope();
  return 0;
}

# MLIR-LABEL: func.func @releaseAtLoopScope
# MLIR: scf.for
# MLIR: mulberry_core.tensor.dispose
# MLIR-LABEL: func.func @releaseFromAtLoopScope
# MLIR: scf.for
# MLIR: mulberry_core.tensor.dispose
# MLIR-LABEL: func.func @std_tensor_Tensor_dispose__UInt8
# MLIR: mulberry_core.tensor.dispose

# LOWERED-DAG: llvm.func @mulberry_tensor_storage_dispose
# LOWERED-DAG: llvm.func @mulberry_tensor_storage_register
# LOWERED-LABEL: func.func @releaseAtLoopScope
# LOWERED: scf.for
# LOWERED: llvm.call @mulberry_tensor_storage_dispose
# LOWERED-LABEL: func.func @releaseFromAtLoopScope
# LOWERED: scf.for
# LOWERED: llvm.call @mulberry_tensor_storage_dispose
# LOWERED-LABEL: func.func @std_tensor_Tensor_dispose__UInt8
# LOWERED: llvm.call @mulberry_tensor_storage_dispose
# LOWERED-LABEL: func.func @std_tensor_from__Array_UInt8
# LOWERED: memref.alloc
# LOWERED: llvm.call @mulberry_tensor_storage_register

