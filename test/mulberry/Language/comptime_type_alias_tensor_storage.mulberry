# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

comptime ShapedBuffer<T, Rank: UInt64> = struct {
  data: Ptr<T>,
  rank: UInt64
};

comptime Buffer2D<T> = ShapedBuffer<T, 2>;

fn main(): UInt64 {
  var data: Ptr<Float32> = heap.alloc<Float32>(4);
  var buffer: Buffer2D<Float32> = ShapedBuffer<Float32, 2> { data, 2 };
  buffer.rank
}

# AST: ComptimeTypeAliasDecl {{.*}}name=ShapedBuffer parameter=T, Rank: UInt64 type=struct {data: Ptr<T>, rank: UInt64}
# AST: ComptimeTypeAliasDecl {{.*}}name=Buffer2D parameter=T type=ShapedBuffer<T, 2>
# AST: VariableStat (id=buffer
# AST-SAME: type=Buffer2D<Float32>

# MLIR-LABEL: func.func @main()
# MLIR: !mulberry_core.record<ShapedBuffer__Float32__2
# MLIR: mulberry_core.record.get_field {{.*}}["rank"]
