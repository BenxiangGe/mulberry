# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import safetensors;

fn main(): UInt64 {
  var a: Tensor<Float32> = tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var b: Tensor<Float32> = tensor.from([[5.0], [6.0]]);
  var names: List<String> = list.from(["a", "b"]);
  var values: List<Tensor<Float32>> = list.from([a, b]);

  safetensors.write("/tmp/mulberry_safetensors_write_checkpoint_jit.safetensors",
                    names, values);

  const file: safetensors.TensorFile =
      safetensors.open("/tmp/mulberry_safetensors_write_checkpoint_jit.safetensors");
  var readA: Tensor<Float32> = safetensors.read(file, "a");
  var readB: Tensor<Float32> = safetensors.read(file, "b");
  safetensors.close(file);

  io.print(readA.numel());
  io.print(core.boolToUInt64(readA[1, 1] > 3.5));
  io.print(readB.numel());
  io.print(core.boolToUInt64(readB[1, 0] > 5.5));
  0
}

# JIT: 4
# JIT-NEXT: 1
# JIT-NEXT: 2
# JIT-NEXT: 1
