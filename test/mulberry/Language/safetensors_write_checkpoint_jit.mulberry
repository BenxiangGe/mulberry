# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import safetensors;

fn run(): Result<UInt64, safetensors.SafetensorsError> {
  var a = tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var b = tensor.from([[5.0], [6.0]]);
  var names = list.from(["a", "b"]);
  var values = list.from([a, b]);

  safetensors.write("/tmp/mulberry_safetensors_write_checkpoint_jit.safetensors",
                    names, values)?;

  const file =
      safetensors.open("/tmp/mulberry_safetensors_write_checkpoint_jit.safetensors")?;
  var readA = safetensors.read(file, "a")?;
  var readB = safetensors.read(file, "b")?;
  safetensors.close(file)?;

  io.println(readA.numel());
  io.println(core.boolToUInt64(readA[1, 1] > 3.5));
  io.println(readB.numel());
  io.println(core.boolToUInt64(readB[1, 0] > 5.5));
  return Ok(0);
}

fn main(): UInt64 {
  return match run() {
    Ok(status) => status,
    Err(error) => 1,
  };
}

# JIT: 4
# JIT-NEXT: 1
# JIT-NEXT: 2
# JIT-NEXT: 1
