# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

comptime BoxStorage<T> = struct {
  value: T,

  pub fn get(self: BoxStorage<T>): T {
    return self.value;
  }
};

fn main(): UInt64 {
  var box: BoxStorage<UInt64> = BoxStorage<UInt64> { 42 };
  io.println(box.get());
  return 0;
}

# AST: ComptimeTypeAliasDecl {{.*}}name=BoxStorage parameter=T type=struct {value: T, fn BoxStorage.get}
# AST: CallExpr {{.*}}callee=BoxStorage_get__UInt64
# AST: Prototype {{.*}}name=BoxStorage_get__UInt64

# JIT: 42
