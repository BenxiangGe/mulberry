# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var w1: Tensor<Float32> = tensor.from([[1.0, 0.0], [0.0, 1.0]]);
  var w2: Tensor<Float32> = tensor.from([[1.0, 1.0]]);
  var weights: List<Tensor<Float32>> = list.from([w1, w2]);
  const first: Tensor<Float32> = weights[0];

  io.print(weights.size());
  io.print(first.numel());
  return 0;
}

