# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Layer {
  weight: Tensor<Float32>
}

fn makeLayer(weight: Tensor<Float32>): Layer {
  return Layer { weight };
}

fn useLayer(layer: Layer): UInt64 {
  return boolToUInt64(layer.weight[0, 1] > 1.5);
}

fn main(): UInt64 {
  var tensor2d: Tensor<Float32> =
      tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var layer: Layer = makeLayer(tensor2d);
  io.print(useLayer(layer));
  return 0;
}

# MLIR-LABEL: func.func @makeLayer
# MLIR-SAME: %arg0: !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# MLIR-SAME: -> !mulberry_core.ptr<!mulberry_core.record<Layer
# MLIR: mulberry_core.record.get_field
# MLIR: mulberry_core.store

# MLIR-LABEL: func.func @useLayer
# MLIR-SAME: %arg0: !mulberry_core.ptr<!mulberry_core.record<Layer
# MLIR: mulberry_core.record.get_field
# MLIR-SAME: ["weight"]
# MLIR: mulberry_core.load
# MLIR: mulberry_core.record.get_field
# MLIR: mulberry_core.ptr.index

# LOWERED-LABEL: func.func @makeLayer
# LOWERED-SAME: %arg0: !llvm.ptr
# LOWERED-SAME: -> !llvm.ptr
# LOWERED-LABEL: func.func @useLayer
# LOWERED-SAME: %arg0: !llvm.ptr
# LOWERED: llvm.getelementptr
# LOWERED: llvm.load
# LOWERED: llvm.getelementptr

# JIT: 1
