# RUN: mulberry-driver -dump=tokens %s 2>&1 | FileCheck %s --check-prefix=TOKENS
# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import io;

fn main(): UInt64 {
  const value = 0x1234_5678_0123;
  io.println(value);
  return 0;
}

# TOKENS: integer_literal '0x1234_5678_0123'

# AST: IntegerLiteralExpr {{.*}}type=UInt64{{.*}}spelling=0x1234_5678_0123

# MLIR: arith.constant 20015998304547 : i64

# JIT: 20015998304547
