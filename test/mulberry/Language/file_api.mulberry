# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED

fn transfer(input: File, output: File, mut bytes: Tensor<UInt8>):
    Result<UInt64, io.FileError> {
  const readCount = io.read(input, bytes)?;
  const writeCount = io.write(output, bytes)?;
  io.close(input)?;
  io.close(output)?;
  return Ok(readCount + writeCount);
}

fn run(): Result<UInt64, io.FileError> {
  const input = io.open("data/mnist.bin", "rb")?;
  io.close(input)?;
  const output = io.open("data/out.bin", "wb")?;
  var bytes: Tensor<UInt8> = tensor.from([1, 2, 3, 4]);
  io.write(output, bytes)?;
  io.close(output)?;
  return Ok(0);
}

fn main(): UInt64 {
  return match run() {
    Ok(status) => status,
    Err(error) => 1,
  };
}

# AST: Prototype {{.*}}name=transfer
# AST: ParameterDecl {{.*}}id=input{{.*}}type=File
# AST: ParameterDecl {{.*}}id=bytes{{.*}}type=Tensor<UInt8>
# AST: CallExpr {{.*}}callee=std_io_read__UInt8
# AST: CallExpr {{.*}}callee=std_io_write__UInt8
# AST: VariableStat {{.*}}id=bytes{{.*}}type=Tensor<UInt8>

# MLIR-DAG: func.func private @mulberry_file_open
# MLIR-DAG: func.func private @mulberry_file_close
# MLIR-LABEL: func.func @std.io.open
# MLIR: call @mulberry_file_open
# MLIR-SAME: -> !mulberry_core.ptr<i8>
# MLIR-LABEL: func.func @std.io.close
# MLIR: call @mulberry_file_close
# MLIR-LABEL: func.func @transfer
# MLIR: call @std_io_read__UInt8
# MLIR: call @std_io_write__UInt8
# MLIR: call @std.io.close
# MLIR-LABEL: func.func @run
# MLIR: call @std.io.open
# MLIR: call @std_tensor_from__Array_UInt8
# MLIR: call @std_io_write__UInt8
# MLIR-LABEL: func.func @std_tensor_from__Array_UInt8
# MLIR: mulberry_core.tensor.storage_alloc i8
# MLIR: call @std_tensor_flattenInto__Array_UInt8
# MLIR-NOT: cir.

# LOWERED-DAG: func.func private @mulberry_file_read(!llvm.ptr, !llvm.ptr, i64) -> i64
# LOWERED-DAG: func.func private @mulberry_file_write(!llvm.ptr, !llvm.ptr, i64) -> i64
# LOWERED-DAG: func.func private @mulberry_file_open
# LOWERED-DAG: func.func private @mulberry_file_close
# LOWERED-LABEL: func.func @std.io.open
# LOWERED: call @mulberry_file_open
# LOWERED-LABEL: func.func @std.io.close
# LOWERED: call @mulberry_file_close
# LOWERED-LABEL: func.func @transfer
# LOWERED: call @std_io_read__UInt8
# LOWERED: call @std_io_write__UInt8
# LOWERED: call @std.io.close
# LOWERED-LABEL: func.func @run
# LOWERED: call @std.io.open
# LOWERED: call @std_io_write__UInt8
# LOWERED: call @mulberry_file_write
