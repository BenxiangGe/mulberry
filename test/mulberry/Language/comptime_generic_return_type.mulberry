# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn make<T>(): Ptr<T> {
  heap.alloc<T>()
}

fn main(): UInt64 {
  var value: Ptr<UInt64> = make();
  *value = 64;
  io.print(*value);
  0
}

# AST: CallExpr {{.*}}callee=make__UInt64
# AST: Prototype {{.*}}name=make__UInt64

# MLIR-LABEL: func.func @main()
# MLIR: call @make__UInt64
# MLIR-DAG: func.func @make__UInt64() -> !mulberry.ptr<i64>

# JIT: 64
