# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn idTensor(value: Tensor<Float32>): Tensor<Float32> {
  return value;
}

fn checkTensor(value: Tensor<Float32>): UInt64 {
  return boolToUInt64(value[1, 1] > 3.5);
}

fn main(): UInt64 {
  var tensor2d: Tensor<Float32> =
      tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var returned: Tensor<Float32> = idTensor(tensor2d);
  io.print(checkTensor(returned));
  return 0;
}

# MLIR-LABEL: func.func @idTensor
# MLIR-SAME: %arg0: !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# MLIR-SAME: -> !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# MLIR: return %{{.*}} : !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32

# MLIR-LABEL: func.func @checkTensor
# MLIR-SAME: %arg0: !mulberry_core.ptr<!mulberry_core.record<std_tensor_Tensor__Float32
# MLIR: mulberry_core.record.get_field %{{.*}}["data"]
# MLIR: mulberry_core.record.get_field %{{.*}}["strides"]
# MLIR: mulberry_core.ptr.index

# LOWERED-LABEL: func.func @idTensor
# LOWERED-SAME: %arg0: !llvm.ptr
# LOWERED-SAME: -> !llvm.ptr
# LOWERED: return %{{.*}} : !llvm.ptr
# LOWERED-LABEL: func.func @checkTensor
# LOWERED-SAME: %arg0: !llvm.ptr

# JIT: 1
