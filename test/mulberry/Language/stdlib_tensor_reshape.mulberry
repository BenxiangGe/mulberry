# RUN: mulberry-driver -typecheck %s
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var matrix: Tensor<Float32> =
      tensor.from([[1.0, 2.0], [3.0, 4.0]]);
  var row: Tensor<Float32> = tensor.reshape(matrix, [1, 4]);

  io.print(row.ndim());
  io.print(row.dim(0));
  io.print(row.dim(1));
  row[0, 3] = 9.0;
  io.print(boolToUInt64(matrix[1, 1] == 9.0));
  return 0;
}

# JIT: 2
# JIT-NEXT: 1
# JIT-NEXT: 4
# JIT-NEXT: 1
