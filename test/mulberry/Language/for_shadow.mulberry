# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var i: UInt64 = 7;
  io.print(i);

  for i in 0 .. 2 {
    io.print(i);
  }

  io.print(i);
  return 0;
}

# CHECK-LABEL: func.func @main
# CHECK: %[[OUTER:.*]] = mulberry_core.alloca i64 : !mulberry_core.ptr<i64>
# CHECK: arith.constant 7 : i64
# CHECK: mulberry_core.store {{.*}}, %[[OUTER]] : i64, !mulberry_core.ptr<i64>
# CHECK: %[[INNER:.*]] = mulberry_core.alloca i64 : !mulberry_core.ptr<i64>
# CHECK: scf.for unsigned
# CHECK: mulberry_core.store {{.*}}, %[[INNER]] : i64, !mulberry_core.ptr<i64>
# CHECK: mulberry_core.load %[[OUTER]] : !mulberry_core.ptr<i64> -> i64
# CHECK-NOT: cir.
