# RUN: mulberry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: mulberry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: mulberry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  io.print(11);
  0
}

# AST: Prototype {{.*}}name=printU64
# AST: Prototype {{.*}}name=printNewline
# AST: Prototype {{.*}}name=std.io.print
# AST: CallExpr {{.*}}type=Unit callee=printU64
# AST: CallExpr {{.*}}type=Unit callee=printNewline
# AST: CallExpr {{.*}}type=UInt64 callee=std.io.print

# MLIR: func.func private @printU64(i64)
# MLIR: func.func private @printNewline()
# MLIR-LABEL: func.func @std.io.print
# MLIR: call @printU64
# MLIR: call @printNewline
# MLIR-LABEL: func.func @main
# MLIR: call @std.io.print

# JIT: 11
