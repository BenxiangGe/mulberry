# RUN: cherry-driver -dump=tokens %s 2>&1 | FileCheck %s --check-prefix=TOKENS
# RUN: cherry-driver -dump=parse %s 2>&1 | FileCheck %s --check-prefix=PARSE

fn main(): UInt64 {
  for i in 0 .. size(xs) {
    io.print(i);
    ()
  };

  0
}

# TOKENS: kw_for 'for'
# TOKENS: identifier 'i'
# TOKENS: kw_in 'in'
# TOKENS: dot_dot '..'

# PARSE: ForExpr
# PARSE-SAME: variable=i
# PARSE: DecimalExpr
# PARSE-SAME: value=0
# PARSE: CallExpr
# PARSE-SAME: callee=size
# PARSE: bodyBlock:
