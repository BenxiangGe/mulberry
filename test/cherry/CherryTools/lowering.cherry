// RUN: cherry-opt --convert-cherry-to-scf --convert-cherry-to-arith-cf-func %s \
// RUN:   | FileCheck %s

module  {
  func.func @main() -> i64 {
    %0 = arith.constant 10 : i64
    %1 = "cherry.print"(%0) : (i64) -> i64
    %2 = arith.constant 0 : i64
    func.return %2 : i64
  }
}

// CHECK: func.func @main() -> i64
// CHECK: arith.constant 10 : i64
// CHECK: cherry.print
// CHECK: return
// CHECK-NOT: llvm.
