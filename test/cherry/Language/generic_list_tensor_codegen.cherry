# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn first(weights: List<Float32[?, ?]>): Float32[?, ?] {
  collections.get(weights, 0)
}

fn make(): List<Float32[?, ?]> {
  var w1: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var w2: Float32[?, ?] = [[5.0, 6.0]];
  var weights: List<Float32[?, ?]> = [w1, w2];
  weights
}

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var w2: Float32[?, ?] = [[5.0, 6.0]];
  var weights: List<Float32[?, ?]> = [w1, w2];
  const layer: Float32[?, ?] = first(weights);
  size(layer) + collections.size(make())
}

# CHECK-LABEL: func.func @first(%arg0: !mulberry.ptr<!mulberry.record<std_collections_ListStorage__Float32______
# CHECK-SAME: -> !mulberry.tensor<?x?xf32>
# CHECK: call @std_collections_get__Float32______
# CHECK-LABEL: func.func @make()
# CHECK-SAME: -> !mulberry.ptr<!mulberry.record<std_collections_ListStorage__Float32______
# CHECK: mulberry.tensor.alloc
# CHECK: mulberry.tensor.alloc
# CHECK: call @std_collections_withCapacity__Float32______
# CHECK: call @std_collections_push__Float32______
# CHECK-LABEL: func.func @main()
# CHECK: call @std_collections_withCapacity__Float32______
# CHECK: call @std_collections_push__Float32______
# CHECK: call @first
# CHECK: call @make
# CHECK: call @std_collections_size__Float32______
# CHECK-NOT: mulberry.list.create
# CHECK-NOT: mulberry.list.get
# CHECK-NOT: mulberry.list.size
