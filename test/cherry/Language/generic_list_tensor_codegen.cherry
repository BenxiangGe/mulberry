# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn first(weights: List<Tensor<Float32, 2>>): Tensor<Float32, 2> {
  weights[0]
}

fn make(): List<Tensor<Float32, 2>> {
  var w1: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var w2: Float32[?, ?] = [[5.0, 6.0]];
  var w1h: Tensor<Float32, 2> = tensor.pack(w1);
  var w2h: Tensor<Float32, 2> = tensor.pack(w2);
  var weights: List<Tensor<Float32, 2>> = [w1h, w2h];
  weights
}

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var w2: Float32[?, ?] = [[5.0, 6.0]];
  var w1h: Tensor<Float32, 2> = tensor.pack(w1);
  var w2h: Tensor<Float32, 2> = tensor.pack(w2);
  var weights: List<Tensor<Float32, 2>> = [w1h, w2h];
  const layer: Tensor<Float32, 2> = first(weights);
  size(layer) + make().size()
}

# CHECK-LABEL: func.func @first(%arg0: !mulberry.ptr<!mulberry.record<std_collections_ListStorage__
# CHECK-SAME: -> !mulberry.ptr<!mulberry.record<std_tensor_TensorStorage__Float32__2
# CHECK: call @std_collections_ListStorage_get__
# CHECK-LABEL: func.func @make()
# CHECK-SAME: -> !mulberry.ptr<!mulberry.record<std_collections_ListStorage__
# CHECK: mulberry.tensor.alloc
# CHECK: mulberry.tensor.alloc
# CHECK: mulberry.tensor.pack
# CHECK: call @std_collections_withCapacity__
# CHECK: call @std_collections_ListStorage_push__
# CHECK-LABEL: func.func @main()
# CHECK: call @std_collections_withCapacity__
# CHECK: call @std_collections_ListStorage_push__
# CHECK: call @first
# CHECK: mulberry.tensor.view
# CHECK: call @make
# CHECK: call @std_collections_ListStorage_size__
