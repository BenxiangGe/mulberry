# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var outputBytes: UInt8[4] = [10, 20, 30, 40];
  const output: File = open("/tmp/cherry_file_api_jit.bin", "wb");
  write(output, outputBytes);
  close(output);

  var inputBytes: UInt8[4] = [0, 0, 0, 0];
  const input: File = open("/tmp/cherry_file_api_jit.bin", "rb");
  const count: UInt64 = read(input, inputBytes);
  close(input);

  io.print(count);
  print(inputBytes[0]);
  print(inputBytes[1]);
  print(inputBytes[2]);
  print(inputBytes[3]);
  0
}

# JIT: 4
# JIT-NEXT: 10
# JIT-NEXT: 20
# JIT-NEXT: 30
# JIT-NEXT: 40
