# RUN: cherry-driver -typecheck %s
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

comptime LocalVector<T> = List<T>;

fn first(xs: LocalVector<UInt64>): UInt64 {
  xs[0]
}

fn main(): UInt64 {
  const xs: LocalVector<UInt64> = [9, 8];
  first(xs)
}

# CHECK: func.func @first(%arg0: !mulberry.list<i64>) -> i64
