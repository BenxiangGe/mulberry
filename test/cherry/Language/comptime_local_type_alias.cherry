# RUN: cherry-driver -typecheck %s
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

comptime LocalVector<T> = List<T>;

fn first(xs: LocalVector<UInt64>): UInt64 {
  xs[0]
}

fn main(): UInt64 {
  var xs: LocalVector<UInt64> = [9, 8];
  first(xs)
}

# CHECK: func.func @first(%arg0: !mulberry.record<std_collections_List__UInt64
# CHECK-SAME: -> i64
# CHECK: call @std_collections_List_get__UInt64
