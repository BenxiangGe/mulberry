# RUN: cherry-driver -dump=tokens %s 2>&1 | FileCheck %s --check-prefix=TOKENS
# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

fn main(): UInt64 {
  const answer: UInt64 = 42;
  const weights: Float32[2, 2] = [[1.0, 2.0], [3.0, 4.0]];
  const tensorValue: Tensor<Float32> = tensor.pack(weights);

  answer + tensorValue.numel()
}

# TOKENS: kw_const 'const'
# TOKENS: kw_const 'const'

# AST: VariableStat const
# AST-SAME: id=answer
# AST: VariableStat const
# AST-SAME: id=weights

# MLIR: arith.constant 42 : i64
# MLIR: mulberry.tensor.pack
# MLIR: call @std_tensor_Tensor_numel__Float32
# MLIR-NOT: cir.
