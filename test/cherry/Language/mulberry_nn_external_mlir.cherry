# RUN: cherry-driver --dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR --implicit-check-not=mulberry_nn
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED

import mulberry.nn;

fn main(): UInt64 {
  var values: Float32[?, ?] = [[1.0], [2.0]];
  var input: Tensor<Float32> = tensor.pack(values);
  var output: Tensor<Float32> = nn.sigmoid(input);
  nn.argmax(output)
}

# MLIR-DAG: func.func private @mulberry.nn.sigmoid
# MLIR-DAG: func.func private @mulberry.nn.argmax
# MLIR-LABEL: func.func @main
# MLIR: call @mulberry.nn.sigmoid
# MLIR: call @mulberry.nn.argmax

# LOWERED-LABEL: func.func @main
# LOWERED: linalg.map
# LOWERED: arith.cmpf ogt
# LOWERED: return
# LOWERED-NOT: call @mulberry.nn
# LOWERED-NOT: mulberry_nn.
# LOWERED-NOT: mulberry.tensor.
