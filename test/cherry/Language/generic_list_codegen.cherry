# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER

fn first(xs: List<UInt64>): UInt64 {
  xs[0]
}

fn make(): List<UInt64> {
  [1, 2, 3]
}

fn main(): UInt64 {
  const numbers: List<UInt64> = [4, 5, 6];
  print(first(numbers));
  size(make())
}

# CHECK-LABEL: func.func @first(%arg0: !mulberry.list<i64>) -> i64
# CHECK: mulberry.list.get %arg0
# CHECK-SAME: !mulberry.list<i64> -> i64
# CHECK-LABEL: func.func @make() -> !mulberry.list<i64>
# CHECK: mulberry.list.create
# CHECK-SAME: !mulberry.list<i64>
# CHECK-LABEL: func.func @main()
# CHECK: mulberry.list.create
# CHECK-SAME: !mulberry.list<i64>
# CHECK: call @first
# CHECK: call @make
# CHECK: mulberry.list.size
# CHECK-SAME: !mulberry.list<i64>

# LOWER-DAG: llvm.func @free(!llvm.ptr)
# LOWER-DAG: llvm.func @malloc(i64) -> !llvm.ptr
# LOWER-LABEL: func.func @first
# LOWER-SAME: !llvm.struct<(i64, ptr)>
# LOWER: llvm.extractvalue
# LOWER: llvm.load
# LOWER-LABEL: func.func @make
# LOWER-SAME: -> !llvm.struct<(i64, ptr)>
# LOWER: memref.alloc
# LOWER: llvm.call @malloc
# LOWER: scf.for
# LOWER: llvm.store
# LOWER: llvm.insertvalue
# LOWER-LABEL: func.func @main
# LOWER: call @first
# LOWER: call @make
# LOWER: llvm.extractvalue
# LOWER: llvm.call @free
# LOWER-NOT: mulberry.
