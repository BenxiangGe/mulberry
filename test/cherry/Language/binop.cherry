# RUN: cherry-driver -b=llvm %s 2>&1 | FileCheck %s
# RUN: cherry-driver -b=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  12345 + 54321;
  12345 - 54321;
  12345 * 54321;
  54321 / 12345;
  54321 % 12345;

  12345 eq 54321;
  12345 neq 54321;
  12345 lt 54321;
  12345 le 54321;
  12345 gt 54321;
  12345 ge 54321;

  123456789
}

# CHECK: 10
# CHECK: 20
