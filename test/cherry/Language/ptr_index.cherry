# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Pair {
  x: UInt64,
  y: Bool
}

fn scalar(): UInt64 {
  var p: Ptr<UInt64> = heap.alloc<UInt64>(3);
  p[0] = 10;
  p[1] = 32;
  p[0] + p[1]
}

fn record(): UInt64 {
  var p: Ptr<Pair> = heap.alloc<Pair>(2);
  p[0].x = 5;
  p[1].x = 8;
  p[0].x + p[1].x
}

fn main(): UInt64 {
  io.print(scalar());
  io.print(record());
  0
}

