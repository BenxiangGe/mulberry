# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver -dump=mlir-llvm %s 2>&1 | FileCheck %s --check-prefix=LLVM

fn choose(values: Float32[2], scale: Float32, enabled: Bool): Float32 {
  if enabled {
    scale
  } else {
    values[0]
  }
}

fn main(): UInt64 {
  var values: Float32[2] = [1.0, 2.0];
  var scale: Float32 = 3.0;
  var offset: Float32 = 1.0;
  var enabled: Bool = true;
  var y: Float32 = choose(values, scale + offset, enabled);
  0
}

# MLIR-LABEL: func.func @choose(%arg0: memref<2xf32>, %arg1: f32, %arg2: i1) -> f32
# MLIR: scf.if {{.*}} -> (f32)
# MLIR-LABEL: func.func @main() -> i64
# MLIR: arith.addf
# MLIR: call @choose({{.*}}) : (memref<2xf32>, f32, i1) -> f32
# MLIR-NOT: cherry.bridge_cast

# LLVM-LABEL: llvm.func @choose
# LLVM-SAME: %arg5: f32, %arg6: i1
# LLVM-LABEL: llvm.func @main
# LLVM: llvm.call @choose
# LLVM-NOT: cherry.bridge_cast
