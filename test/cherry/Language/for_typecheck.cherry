# RUN: cherry-driver -typecheck %s
# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var xs: UInt64[3] = [1, 2, 3];

  for i in 0 .. 3 {
    io.print(i);
  }

  0
}

# CHECK: ForExpr
# CHECK-SAME: type=Unit
# CHECK-SAME: variable=i
# CHECK: bodyBlock:
# CHECK-NEXT: CallExpr
# CHECK-SAME: callee=std.io.print
# CHECK-NEXT: VariableExpr
# CHECK-SAME: type=UInt64
# CHECK-SAME: name=i
