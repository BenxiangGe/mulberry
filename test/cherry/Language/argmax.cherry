# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# TODO: Re-enable linalg checks after Tensor-to-memref lowering exists.

fn main(): UInt64 {
  var a: Float32[4] = [1.0, 9.0, 3.0, 2.0];
  var i: UInt64 = argmax(a);

  i
}

# MLIR: cherry_nn.argmax
# MLIR-SAME: !mulberry.tensor<4xf32> -> i64
# MLIR-NOT: cherry_nn.cast
# MLIR-NOT: cir.
# MLIR-NOT: memref.
