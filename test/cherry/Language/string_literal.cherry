# RUN: cherry-driver -dump=tokens %s 2>&1 | FileCheck %s --check-prefix=TOKENS
# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED

fn id(path: String): String {
  path
}

fn main(): UInt64 {
  const path: String = "data/mnist.bin";
  const copy: String = id(path);
  0
}

# TOKENS: string_literal '"data/mnist.bin"'

# AST: StringLiteralExpr
# AST-SAME: type=String

# MLIR: func.func @id(%arg0: !mulberry.string) -> !mulberry.string
# MLIR: mulberry.alloca !mulberry.string : !mulberry.ptr<!mulberry.string>
# MLIR: mulberry.string.literal "data/mnist.bin" : !mulberry.string
# MLIR: call @id
# MLIR-NOT: cir.

# LOWERED: llvm.mlir.global internal constant @__mulberry_string_0
# LOWERED-LABEL: func.func @id(%arg0: !llvm.struct<(i64, ptr)>) -> !llvm.struct<(i64, ptr)>
# LOWERED: llvm.insertvalue
# LOWERED-SAME: [0]
# LOWERED: llvm.insertvalue
# LOWERED-SAME: [1]
# LOWERED-NOT: mulberry.
