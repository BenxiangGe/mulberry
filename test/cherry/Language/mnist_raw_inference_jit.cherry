# RUN: %numpy_python %cherry_src_root/tools/export_mnist_raw_tensors.py --output-dir /tmp/cherry_mnist_raw_inference > %t.export.log && cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var w1: Float32[30, 784] = zeros();
  var b1: Float32[30, 1] = zeros();
  var w2: Float32[10, 30] = zeros();
  var b2: Float32[10, 1] = zeros();
  var x: Float32[784, 1] = zeros();

  const w1File: File = io.open("/tmp/cherry_mnist_raw_inference/w1.f32", "rb");
  const w1Count: UInt64 = read(w1File, w1);
  io.close(w1File);

  const b1File: File = io.open("/tmp/cherry_mnist_raw_inference/b1.f32", "rb");
  const b1Count: UInt64 = read(b1File, b1);
  io.close(b1File);

  const w2File: File = io.open("/tmp/cherry_mnist_raw_inference/w2.f32", "rb");
  const w2Count: UInt64 = read(w2File, w2);
  io.close(w2File);

  const b2File: File = io.open("/tmp/cherry_mnist_raw_inference/b2.f32", "rb");
  const b2Count: UInt64 = read(b2File, b2);
  io.close(b2File);

  const xFile: File = io.open("/tmp/cherry_mnist_raw_inference/x.f32", "rb");
  const xCount: UInt64 = read(xFile, x);
  io.close(xFile);

  io.print(w1Count);
  io.print(b1Count);
  io.print(w2Count);
  io.print(b2Count);
  io.print(xCount);

  var w1h: Tensor<Float32, 2> = tensor.pack(w1);
  var b1h: Tensor<Float32, 2> = tensor.pack(b1);
  var w2h: Tensor<Float32, 2> = tensor.pack(w2);
  var b2h: Tensor<Float32, 2> = tensor.pack(b2);
  var xh: Tensor<Float32, 2> = tensor.pack(x);

  var weights: List<Tensor<Float32, 2>> = [w1h, w2h];
  var biases: List<Tensor<Float32, 2>> = [b1h, b2h];
  var activation: Tensor<Float32, 2> = xh;

  for layer in 0 .. weights.size() {
    activation = sigmoid(matadd(
        matmul(weights[layer], activation),
        biases[layer]));
    ()
  };

  io.print(argmax(activation));
  0
}

