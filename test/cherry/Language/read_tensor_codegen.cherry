# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  const file: File = io.open("data/mnist-784-30-10.safetensors", "rb");
  var w1: Float32[?, ?] = readTensor(file, "w1");
  io.close(file);
  size(w1)
}

# CHECK-LABEL: func.func @main
# CHECK: mulberry.heap.alloc i8
# CHECK: mulberry.ptr.index
# CHECK: mulberry.heap.alloc !mulberry.record<std.string.StringStorage
# CHECK: mulberry.record.get_field {{.*}}["length"]
# CHECK: mulberry.record.get_field {{.*}}["data"]
# CHECK: call @std.io.open
# CHECK-SAME: -> !mulberry.ptr<!mulberry.record<std.io.FileStorage {handle: !mulberry.ptr<i8>}>>
# CHECK: mulberry.heap.alloc !mulberry.record<std.string.StringStorage
# CHECK: call @__cherry_safetensor_read_
# CHECK-SAME: -> !mulberry.tensor<?x?xf32>
# CHECK-NOT: mulberry.string
# CHECK-NOT: mulberry.safetensor
# CHECK-NOT: cir.
