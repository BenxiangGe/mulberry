# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var first: Ptr<UInt64> = heap.alloc<UInt64>();
  var second: Ptr<UInt64> = heap.alloc<UInt64>();
  *first = 11;
  *second = 22;

  var current: Ptr<UInt64> = first;
  current = second;

  io.print(*current);
  0
}

# LOWER-LABEL: func.func @main
# LOWER: llvm.store {{.*}}, {{.*}} : !llvm.ptr, !llvm.ptr
# LOWER: llvm.load {{.*}} : !llvm.ptr -> !llvm.ptr
# LOWER: call @std.io.print
# LOWER-NOT: mulberry.

# JIT: 22
