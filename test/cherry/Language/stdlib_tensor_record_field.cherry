# RUN: cherry-driver -typecheck %s
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Layer {
  weight: Tensor<Float32>
}

fn makeLayer(weight: Tensor<Float32>): Layer {
  Layer { weight }
}

fn useLayer(layer: Layer): UInt64 {
  var view: Float32[?, ?] = tensor.view(layer.weight);
  boolToUInt64(view[0, 1] > 1.5)
}

fn main(): UInt64 {
  var data: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var tensor2d: Tensor<Float32> = tensor.pack(data);
  var layer: Layer = makeLayer(tensor2d);
  io.print(useLayer(layer));
  0
}

# MLIR-LABEL: func.func @makeLayer
# MLIR-SAME: %arg0: !mulberry.record<std_tensor_Tensor__Float32
# MLIR-SAME: -> !mulberry.record<Layer
# MLIR: mulberry.record.get_field
# MLIR: mulberry.store

# MLIR-LABEL: func.func @useLayer
# MLIR-SAME: %arg0: !mulberry.record<Layer
# MLIR: mulberry.record.get_field
# MLIR-SAME: ["weight"]
# MLIR: mulberry.load
# MLIR: mulberry.tensor.view
# MLIR-SAME: -> !mulberry.tensor<?x?xf32>

# LOWERED-LABEL: func.func @makeLayer
# LOWERED-SAME: %arg0: !llvm.struct
# LOWERED-SAME: -> !llvm.struct
# LOWERED: llvm.store %arg0

# LOWERED-LABEL: func.func @useLayer
# LOWERED-SAME: %arg0: !llvm.struct
# LOWERED: llvm.store %arg0
# LOWERED: llvm.getelementptr
# LOWERED: llvm.load
# LOWERED: memref.reinterpret_cast
# LOWERED-NOT: mulberry.tensor.view

# JIT: 1
