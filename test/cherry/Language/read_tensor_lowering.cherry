# RUN: cherry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  const file: File = io.open("data/mnist-784-30-10.safetensors", "rb");
  var w1: Float32[?, ?] = readTensor(file, "w1");
  io.close(file);
  size(w1)
}

# CHECK-DAG: llvm.func @mulberry_safetensor_shape_f32
# CHECK-DAG: llvm.func @mulberry_safetensor_read_f32
# CHECK: llvm.call @mulberry_safetensor_shape_f32
# CHECK: memref.alloc
# CHECK-SAME: memref<?x?xf32>
# CHECK: llvm.call @mulberry_safetensor_read_f32
# CHECK-NOT: __cherry_safetensor_read_
