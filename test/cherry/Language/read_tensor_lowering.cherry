# RUN: cherry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  const file: File = io.open("data/mnist-784-30-10.safetensors", "rb");
  var w1Tensor: Tensor<Float32> = io.readTensor(file, "w1");
  io.close(file);
  var w1: Float32[?, ?] = tensor.view(w1Tensor);
  w1Tensor.numel()
}

# CHECK-DAG: func.func private @mulberry_safetensor_read_tensor_f32
# CHECK: call @mulberry_safetensor_read_tensor_f32
