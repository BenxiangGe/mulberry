# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var data: Ptr<UInt64> = heap.alloc<UInt64>(2);
  var xs: List<UInt64> = collections.withCapacity(2);
  xs.length = 2;
  xs.data = data;
  xs[0] = 42;
  xs[1] = 58;
  io.print(xs.size());
  io.print(xs[0] + xs[1]);
  0
}

# AST: ComptimeTypeAliasDecl {{.*}}name=std.collections.List parameter=T
# AST-DAG: CallExpr {{.*}}callee=std_collections_List_size__UInt64
# AST-DAG: IndexExpr {{.*}}type=UInt64 kind=stdlibList

# MLIR-LABEL: func.func @main()
# MLIR: call @std_collections_withCapacity__UInt64
# MLIR: call @std_collections_List_set__UInt64
# MLIR: call @std_collections_List_size__UInt64
# MLIR: call @std_collections_List_get__UInt64
# MLIR-DAG: func.func @std_collections_List_set__UInt64
# MLIR-DAG: func.func @std_collections_List_size__UInt64
# MLIR-DAG: func.func @std_collections_List_get__UInt64

# JIT: 2
# JIT-NEXT: 100
