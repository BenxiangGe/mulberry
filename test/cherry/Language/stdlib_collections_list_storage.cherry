# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var data: Ptr<UInt64> = heap.alloc<UInt64>(2);
  var xs: Ptr<collections.ListStorage<UInt64>> =
      heap.alloc<collections.ListStorage<UInt64>>();
  xs.length = 2;
  xs.capacity = 2;
  xs.data = data;
  collections.set(xs, 0, 42);
  collections.set(xs, 1, 58);
  io.print(collections.size(xs));
  io.print(collections.get(xs, 0) + collections.get(xs, 1));
  0
}

# AST: ComptimeTypeAliasDecl {{.*}}name=std.collections.ListStorage parameter=T
# AST-DAG: CallExpr {{.*}}callee=std_collections_set__UInt64
# AST-DAG: CallExpr {{.*}}callee=std_collections_size__UInt64
# AST-DAG: CallExpr {{.*}}callee=std_collections_get__UInt64

# MLIR-LABEL: func.func @main()
# MLIR: mulberry.heap.alloc !mulberry.record<std_collections_ListStorage__UInt64
# MLIR: call @std_collections_set__UInt64
# MLIR: call @std_collections_size__UInt64
# MLIR: call @std_collections_get__UInt64
# MLIR-DAG: func.func @std_collections_set__UInt64
# MLIR-DAG: func.func @std_collections_size__UInt64
# MLIR-DAG: func.func @std_collections_get__UInt64

# JIT: 2
# JIT-NEXT: 100
