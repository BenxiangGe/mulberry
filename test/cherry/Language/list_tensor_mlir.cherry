# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  const w1: Float32[2] = [1.0, 2.0];
  const w2: Float32[2] = [3.0, 4.0];
  const weights: List<Float32[2]> = [w1, w2];
  const first: Float32[?] = weights[0];
  const firstSize: UInt64 = size(weights);
  print(firstSize);
  0
}

# CHECK: mulberry.list.create
# CHECK-SAME: !mulberry.list<!mulberry.tensor_desc<memref<2xf32>>>
# CHECK: mulberry.list.get
# CHECK-SAME: <!mulberry.tensor_desc<memref<2xf32>>> -> !mulberry.tensor_desc<memref<2xf32>>
# CHECK: mulberry.tensor.unpack
# CHECK-SAME: <memref<2xf32>> -> memref<2xf32>
# CHECK: memref.cast
# CHECK-SAME: memref<2xf32> to memref<?xf32>
# CHECK: mulberry.list.size
# CHECK-SAME: <!mulberry.tensor_desc<memref<2xf32>>> -> i64
