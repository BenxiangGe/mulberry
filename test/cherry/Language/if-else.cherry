# RUN: cherry-driver %s -dump=mlir 2>&1 | FileCheck %s

fn bar(x: UInt64, y: Bool): Bool {
  var k: Bool = y;

  k = if k {
    false
  } else {
    true
  };

  k
}

fn main(): UInt64 {
  bar(18446744073709551615, false);
  0
}

# CHECK-LABEL: func.func @bar
# CHECK: scf.if {{.*}} -> (i1)
# CHECK: arith.constant false
# CHECK: scf.yield {{.*}} : i1
# CHECK: arith.constant true
# CHECK: scf.yield {{.*}} : i1
# CHECK: return {{.*}} : i1
# CHECK-LABEL: func.func @main
# CHECK: call @bar
# CHECK-NOT: cir.
