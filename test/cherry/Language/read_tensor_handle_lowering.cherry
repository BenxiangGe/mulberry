# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver -dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWERED

fn main(): UInt64 {
  const file: File = io.open("data/mnist-784-30-10.safetensors", "rb");
  var w1Tensor: Tensor<Float32> = io.readTensor(file, "w1");
  io.close(file);
  var w1: Float32[?, ?] = tensor.view(w1Tensor);
  w1Tensor.numel()
}

# MLIR: call @std.io.readTensor
# MLIR: mulberry.tensor.view

# LOWERED-DAG: func.func private @mulberry_safetensor_read_tensor_f32
# LOWERED: call @mulberry_safetensor_read_tensor_f32
# LOWERED-NOT: mulberry.tensor.view
