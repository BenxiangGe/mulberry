# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var data: Float32[?, ?] = [[1.0, 2.0], [3.0, 4.0]];
  var tensor2d: Tensor<Float32> = tensor.pack(data);
  io.print(tensor2d.shape().size());
  tensor2d.numel()
}

# AST: ComptimeTypeAliasDecl {{.*}}name=std.tensor.Tensor parameter=T type=struct {data: Ptr<T>, rank: UInt64, numel: UInt64, sizes: List<UInt64>, strides: List<UInt64>
# AST: VariableStat (id=tensor2d
# AST-SAME: type=Tensor<Float32>
# AST-SAME: origin=std.tensor.Tensor<Float32>

# MLIR-LABEL: func.func @main()
# MLIR: mulberry.tensor.pack
# MLIR: call @std_tensor_Tensor_shape__Float32
# MLIR: call @std_collections_List_size__UInt64
# MLIR: call @std_tensor_Tensor_numel__Float32

# JIT: 2
