# RUN: cherry-driver -typecheck %s
# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

fn use(xs: types.Vector<UInt64>, ys: types.Matrix<Float32>): UInt64 {
  size(xs) + size(ys)
}

fn main(): UInt64 {
  const xs: types.Vector<UInt64> = [1, 2, 3];
  var ys: types.Matrix<Float32> = [[1.0, 2.0], [3.0, 4.0]];
  use(xs, ys)
}

# AST: ComptimeTypeAliasDecl {{.*}}name=std.types.Vector parameter=T type=List<T>
# AST: ComptimeTypeAliasDecl {{.*}}name=std.types.Matrix parameter=T type=T[?, ?]
# AST: Prototype
# AST-SAME: name=use
# AST: VariableStat (id=xs
# AST-SAME: type=types.Vector<UInt64>
# AST: VariableStat (id=ys
# AST-SAME: type=types.Matrix<Float32>
# MLIR: func.func @use(%arg0: !mulberry.list<i64>, %arg1: !mulberry.tensor<?x?xf32>) -> i64
