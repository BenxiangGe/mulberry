# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var w1: Float32[2, 2] = [[1.0, 2.0], [3.0, 4.0]];
  var w2: Float32[1, 2] = [[5.0, 6.0]];

  var weights: List<Float32[?, ?]> = [w1];
  weights = [w2];

  var activation: Float32[?, ?] = w1;
  activation = w2;

  size(weights) + size(activation)
}

# CHECK-LABEL: func.func @main()
# CHECK: mulberry.alloca !mulberry.tensor<?x?xf32>
# CHECK: mulberry.alloca !mulberry.list<!mulberry.tensor<?x?xf32>>
# CHECK: mulberry.tensor.cast {{.*}} : !mulberry.tensor<2x2xf32> to !mulberry.tensor<?x?xf32>
# CHECK: mulberry.store {{.*}} : !mulberry.list<!mulberry.tensor<?x?xf32>>
# CHECK: mulberry.tensor.cast {{.*}} : !mulberry.tensor<1x2xf32> to !mulberry.tensor<?x?xf32>
# CHECK: mulberry.store {{.*}} : !mulberry.list<!mulberry.tensor<?x?xf32>>
# CHECK: mulberry.store {{.*}} : !mulberry.tensor<?x?xf32>
# CHECK: mulberry.load {{.*}} : !mulberry.ptr<!mulberry.list<!mulberry.tensor<?x?xf32>>> -> !mulberry.list<!mulberry.tensor<?x?xf32>>
