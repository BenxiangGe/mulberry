# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var xs: UInt64[3] = [1, 2, 3];
  var sum: UInt64 = 0;

  for i in 0 .. size(xs) {
    sum = sum + xs[i];
    ()
  };

  print(sum);
  0
}

