# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var xs: UInt64[3] = [1, 2, 3];
  var sum: UInt64 = 0;

  for i in 0 .. 3 {
    sum = sum + xs[i];
  }

  io.print(sum);
  0
}

# CHECK: arith.constant 3 : i64
# CHECK: scf.for unsigned
# CHECK: mulberry.load
# CHECK: mulberry.tensor.load
# CHECK: arith.addi
# CHECK-NOT: cir.
