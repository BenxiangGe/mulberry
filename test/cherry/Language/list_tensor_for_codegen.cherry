# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[1.0, 0.0], [0.0, 1.0]];
  var w2: Float32[?, ?] = [[1.0, 1.0]];
  var b1: Float32[?, ?] = [[0.0], [0.0]];
  var b2: Float32[?, ?] = [[0.0]];
  const x: Float32[2, 1] = [[0.2], [0.8]];

  var weights: List<Float32[?, ?]> = [w1, w2];
  var biases: List<Float32[?, ?]> = [b1, b2];
  var activation: Float32[?, ?] = [[0.2], [0.8]];

  for layer in 0 .. collections.size(weights) {
    activation = sigmoid(matadd(
        matmul(collections.get(weights, layer), activation),
        collections.get(biases, layer)));
    ()
  };

  argmax(activation)
}

# CHECK-LABEL: func.func @main()
# CHECK: call @std_collections_withCapacity__Float32______
# CHECK: call @std_collections_push__Float32______
# CHECK: scf.for unsigned
# CHECK: call @std_collections_get__Float32______
# CHECK: cherry_nn.matmul
# CHECK: cherry_nn.matadd
# CHECK: cherry_nn.sigmoid
# CHECK: cherry_nn.argmax

# LOWER-LABEL: func.func @main
# LOWER: call @std_collections_withCapacity__Float32______
# LOWER: call @std_collections_push__Float32______
# LOWER: scf.for unsigned
# LOWER: call @std_collections_get__Float32______
# LOWER: linalg.generic
# LOWER: arith.mulf
# LOWER: arith.addf
# LOWER: linalg.add
# LOWER: linalg.map
# LOWER: linalg.generic
# LOWER: return
# LOWER-NOT: cherry_nn.
# LOWER-NOT: mulberry.
