# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[1.0, 0.0], [0.0, 1.0]];
  var w2: Float32[?, ?] = [[1.0, 1.0]];
  var b1: Float32[?, ?] = [[0.0], [0.0]];
  var b2: Float32[?, ?] = [[0.0]];
  var w1h: Tensor<Float32, 2> = tensor.pack(w1);
  var w2h: Tensor<Float32, 2> = tensor.pack(w2);
  var b1h: Tensor<Float32, 2> = tensor.pack(b1);
  var b2h: Tensor<Float32, 2> = tensor.pack(b2);
  const x: Float32[2, 1] = [[0.2], [0.8]];

  var weights: List<Tensor<Float32, 2>> = [w1h, w2h];
  var biases: List<Tensor<Float32, 2>> = [b1h, b2h];
  var activation: Float32[?, ?] = [[0.2], [0.8]];

  for layer in 0 .. weights.size() {
    activation = sigmoid(matadd(
        matmul(weights[layer], activation),
        biases[layer]));
    ()
  };

  argmax(activation)
}

# CHECK-LABEL: func.func @main()
# CHECK: mulberry.tensor.pack
# CHECK: call @std_collections_withCapacity__
# CHECK: call @std_collections_ListStorage_push__
# CHECK: scf.for unsigned
# CHECK: call @std_collections_ListStorage_get__
# CHECK: cherry_nn.matmul
# CHECK: cherry_nn.matadd
# CHECK: cherry_nn.sigmoid
# CHECK: cherry_nn.argmax

# LOWER-LABEL: func.func @main
# LOWER: call @std_collections_withCapacity__
# LOWER: call @std_collections_ListStorage_push__
# LOWER: scf.for unsigned
# LOWER: call @std_collections_ListStorage_get__
# LOWER: linalg.generic
# LOWER: arith.mulf
# LOWER: arith.addf
# LOWER: linalg.add
# LOWER: linalg.map
# LOWER: linalg.generic
# LOWER: return
# LOWER-NOT: cherry_nn.
# LOWER-NOT: mulberry.
