# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

import std.core;

fn main(): UInt64 {
  core.identity(7)
}

# AST: Prototype {{.*}}name=std.core.identity
# AST: Prototype {{.*}}name=main
# AST: CallExpr {{.*}}type=UInt64 callee=std.core.identity

# MLIR-LABEL: func.func @std.core.identity
# MLIR-LABEL: func.func @main
# MLIR: call @std.core.identity
