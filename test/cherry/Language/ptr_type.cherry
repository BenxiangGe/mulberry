# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

fn idScalar(p: Ptr<UInt64>): Ptr<UInt64> {
  p
}

fn idTensor(p: Ptr<Float32[?, ?]>): Ptr<Float32[?, ?]> {
  p
}

struct Pair {
  x: UInt64,
  y: Bool
}

fn idRecord(p: Ptr<Pair>): Ptr<Pair> {
  p
}

fn idList(p: List<UInt64>):
    List<UInt64> {
  p
}

fn main(): UInt64 {
  0
}

# AST: Prototype {{.*}}name=idScalar{{.*}}type=Ptr<UInt64>
# AST: VariableStat {{.*}}id=p{{.*}}type=Ptr<UInt64>
# AST: Prototype {{.*}}name=idTensor{{.*}}type=Ptr<Float32[?, ?]>
# AST: VariableStat {{.*}}id=p{{.*}}type=Ptr<Float32[?, ?]>
# AST: Prototype {{.*}}name=idRecord{{.*}}type=Ptr<Pair>
# AST: VariableStat {{.*}}id=p{{.*}}type=Ptr<Pair>
# AST: Prototype {{.*}}name=idList{{.*}}type=List<UInt64>
# AST: VariableStat {{.*}}id=p{{.*}}type=List<UInt64>

# MLIR-LABEL: func.func @idScalar(%arg0: !mulberry.ptr<i64>) -> !mulberry.ptr<i64>
# MLIR: return %arg0 : !mulberry.ptr<i64>
# MLIR-LABEL: func.func @idTensor(%arg0: !mulberry.ptr<!mulberry.tensor<?x?xf32>>) -> !mulberry.ptr<!mulberry.tensor<?x?xf32>>
# MLIR: return %arg0 : !mulberry.ptr<!mulberry.tensor<?x?xf32>>
# MLIR-LABEL: func.func @idRecord(%arg0: !mulberry.ptr<!mulberry.record<Pair
# MLIR-SAME: -> !mulberry.ptr<!mulberry.record<Pair
# MLIR: return %arg0 : !mulberry.ptr<!mulberry.record<Pair
# MLIR-LABEL: func.func @idList(%arg0: !mulberry.ptr<!mulberry.record<std_collections_ListStorage__UInt64
# MLIR-SAME: -> !mulberry.ptr<!mulberry.record<std_collections_ListStorage__UInt64
# MLIR: return %arg0 : !mulberry.ptr<!mulberry.record<std_collections_ListStorage__UInt64
