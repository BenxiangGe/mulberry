# RUN: cherry-driver --dump=mlir %s 2>&1 | FileCheck %s

struct Pair {
  x: UInt64,
  y: UInt64
}

struct Box {
  pair: Pair,
  ok: Bool
}

fn makePair(x: UInt64): Pair {
  Pair { x, x + 1 }
}

fn readX(box: Box): UInt64 {
  box.pair.x
}

fn update(box: Box): Box {
  var copy: Box = box;
  copy.pair.x = copy.pair.y;
  copy.ok = false;
  copy
}

fn main(): UInt64 {
  var box: Box = Box { makePair(4), true };
  var changed: Box = update(box);
  readX(changed)
}

# CHECK-LABEL: func.func @makePair
# CHECK-SAME: (%arg0: i64)
# CHECK-SAME: -> !mulberry.record<Pair
# CHECK: mulberry.alloca !mulberry.record<Pair
# CHECK: arith.addi
# CHECK: return {{.*}} : !mulberry.record<Pair

# CHECK-LABEL: func.func @readX
# CHECK-SAME: !mulberry.record<Box
# CHECK: mulberry.store %arg0
# CHECK: mulberry.record.get_field {{.*}}["pair"]
# CHECK: mulberry.record.get_field {{.*}}["x"]
# CHECK: return {{.*}} : i64

# CHECK-LABEL: func.func @update
# CHECK-SAME: !mulberry.record<Box
# CHECK-SAME: -> !mulberry.record<Box
# CHECK: mulberry.record.get_field {{.*}}["pair"]
# CHECK: mulberry.record.get_field {{.*}}["x"]
# CHECK: mulberry.record.get_field {{.*}}["pair"]
# CHECK: mulberry.record.get_field {{.*}}["y"]
# CHECK: mulberry.store
# CHECK: mulberry.record.get_field {{.*}}["ok"]
# CHECK: arith.constant false
# CHECK: return {{.*}} : !mulberry.record<Box

# CHECK-LABEL: func.func @main
# CHECK: call @makePair
# CHECK: call @update
# CHECK: call @readX
# CHECK-NOT: cir.
