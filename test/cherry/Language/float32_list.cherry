# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var t: list<Float32, 2> = [1.25, 2.5];
  t[1] = 3.5;

  var tensor: Float32[2, 2] = [[1.0, 2.0], [3.0, 4.0]];
  tensor[1, 0] = t[0];

  0
}

# CHECK: memref.alloc() : memref<2xf32>
# CHECK: arith.constant {{.*}} : f32
# CHECK: memref.store
# CHECK-SAME: memref<2xf32>
# CHECK: arith.constant {{.*}} : f32
# CHECK: memref.store
# CHECK-SAME: memref<2xf32>
# CHECK: memref.alloc() : memref<2x2xf32>
# CHECK: memref.load
# CHECK-SAME: memref<2xf32>
# CHECK: memref.store
# CHECK-SAME: memref<2x2xf32>
