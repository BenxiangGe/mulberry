# RUN: %numpy_python %cherry_src_root/tools/export_mnist_safetensors.py --output /tmp/cherry_mnist_read_tensor.safetensors > %t.export.log && cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  const file: File = open("/tmp/cherry_mnist_read_tensor.safetensors", "rb");
  var x: Float32[?, ?] = readTensor(file, "x");
  close(file);

  print(size(x));
  0
}

