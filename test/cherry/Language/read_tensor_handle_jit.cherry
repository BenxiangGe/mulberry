# RUN: %numpy_python %cherry_src_root/tools/export_mnist_safetensors.py --output /tmp/cherry_mnist_read_tensor_handle.safetensors > %t.export.log && cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  const file: File = io.open("/tmp/cherry_mnist_read_tensor_handle.safetensors",
                             "rb");
  var xHandle: Tensor<Float32, 2> = readTensor(file, "x");
  io.close(file);

  var x: Float32[?, ?] = tensor.view(xHandle);
  io.print(size(x));
  0
}

# JIT: 784
