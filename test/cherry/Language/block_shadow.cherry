# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var value: UInt64 = 1;
  io.print(value);

  if true {
    var value: UInt64 = 2;
    io.print(value);
  } else {
  }

  io.print(value);
  0
}

# CHECK: %[[OUTER:.*]] = mulberry.alloca i64 : !mulberry.ptr<i64>
# CHECK: arith.constant 1 : i64
# CHECK: mulberry.store {{.*}}, %[[OUTER]] : i64, !mulberry.ptr<i64>
# CHECK: scf.if
# CHECK: %[[INNER:.*]] = mulberry.alloca i64 : !mulberry.ptr<i64>
# CHECK: arith.constant 2 : i64
# CHECK: mulberry.store {{.*}}, %[[INNER]] : i64, !mulberry.ptr<i64>
# CHECK: mulberry.load %[[OUTER]] : !mulberry.ptr<i64> -> i64
# CHECK-NOT: cir.
