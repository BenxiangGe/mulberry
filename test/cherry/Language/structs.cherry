# RUN: cherry-driver %s -typecheck

struct C {
  a: Bool
}
struct A {
  x: Bool,
  y: UInt64,
  c: C
}
struct B {
  k: UInt64,
  a: A
}
struct D {
  u: UInt64,
  v: Bool
}
struct E {
   ec: C
}

fn main(): UInt64 {
  # var b: B = B { 10000, A { false, 11000, C { true } } };
  # var v: B = B { 20000, A { false, 22000, C { true } } };
  # v = b;
  # var cc: C = C { false };
  # cc.a;
  # D { 12345, true };
  # var cc: C = C { true };
  # E { C { true } };
  var e: E = E { C { true } };
  e.ec.a = false;
  # E { cc };
  # A { false, 20, C { true } };
  # B { 10, A { false, 20, C { true } } };

  # io.print(value.k);
  # CHECK: 10

  # io.print(boolToUInt64(value.a.x));
  # CHECK: 0
  
  # io.print(value.a.y);
  # CHECK: 20

  # var x: C = value.a.c;
  0
}
