# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[1.0, 0.0], [0.0, 1.0]];
  var w2: Float32[?, ?] = [[1.0, 1.0]];
  var w1h: Tensor<Float32> = tensor.pack(w1);
  var w2h: Tensor<Float32> = tensor.pack(w2);
  var weights: List<Tensor<Float32>> = [w1h, w2h];
  const first: Tensor<Float32> = weights[0];

  io.print(weights.size());
  io.print(first.numel());
  0
}

# AST: VariableStat (id=weights
# AST-NEXT: ArrayLiteralExpr {{.*}} type=std_collections_List__
# AST-DAG: IndexExpr {{.*}}kind=stdlibList

