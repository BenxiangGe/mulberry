# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[1.0, 0.0], [0.0, 1.0]];
  var w2: Float32[?, ?] = [[1.0, 1.0]];
  var w1h: Tensor<Float32> = tensor.pack(w1);
  var w2h: Tensor<Float32> = tensor.pack(w2);
  var weights: List<Tensor<Float32>> = [w1h, w2h];

  var x: Float32[?, ?] = [[0.2], [0.8]];
  var y: Float32[?, ?] =
      matmul(weights[0], x);
  io.print(argmax(y));
  0
}

# AST: VariableStat (id=weights
# AST-NEXT: ArrayLiteralExpr {{.*}} type=std_collections_List__
# AST-DAG: IndexExpr {{.*}}kind=stdlibList

# MLIR-LABEL: func.func @main()
# MLIR: mulberry.tensor.pack
# MLIR: call @std_collections_withCapacity__
# MLIR: call @std_collections_List_push__
# MLIR: call @std_collections_List_get__
# MLIR-DAG: func.func @std_collections_List_push__
# MLIR-DAG: mulberry.ptr.index

# LOWER-LABEL: func.func @main()
# LOWER: call @std_collections_withCapacity__
# LOWER: call @std_collections_List_push__
# LOWER: call @std_collections_List_get__
# LOWER-DAG: llvm.getelementptr
# LOWER-DAG: memref.reinterpret_cast
# LOWER-DAG: linalg.generic

# JIT: 1
