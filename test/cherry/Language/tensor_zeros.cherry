# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var values: Float32[4] = zeros();
  values[2] = 1.0;
  io.print(boolToUInt64(values[2] > 0.5));
  0
}

# AST: TensorZerosExpr {{.*}}type=Float32[4]
# AST: IndexExpr {{.*}}type=Float32 kind=tensor

# MLIR: mulberry.tensor.alloc() : !mulberry.tensor<4xf32>
# MLIR: arith.constant {{.*}} : f32
# MLIR: mulberry.tensor.store
# MLIR-SAME: !mulberry.tensor<4xf32>

# JIT: 1
