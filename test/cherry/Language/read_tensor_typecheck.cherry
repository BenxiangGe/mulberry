# RUN: cherry-driver -typecheck %s
# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  const file: File = io.open("data/mnist-784-30-10.safetensors", "rb");
  var w1: Tensor<Float32> = io.readTensor(file, "w1");
  var b1: Tensor<Float32> = io.readTensor(file, "b1");
  io.close(file);
  0
}

# CHECK: CallExpr {{.*}}type=std_tensor_Tensor__Float32 callee=std.io.readTensor
# CHECK: CallExpr {{.*}}type=std_tensor_Tensor__Float32 callee=std.io.readTensor
