# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[0.1, 0.2], [0.3, 0.4]];
  var w2: Float32[?, ?] = [[0.5, 0.6]];
  var b1: Float32[?, ?] = [[0.01], [0.02]];
  var b2: Float32[?, ?] = [[0.03]];
  var x0: Float32[?, ?] = [[0.7], [0.8]];
  var x1: Float32[?, ?] = [[0.2], [0.4]];
  var y0: Float32[?, ?] = [[1.0]];
  var y1: Float32[?, ?] = [[0.0]];
  var x0h: Tensor<Float32, 2> = tensor.pack(x0);
  var x1h: Tensor<Float32, 2> = tensor.pack(x1);
  var y0h: Tensor<Float32, 2> = tensor.pack(y0);
  var y1h: Tensor<Float32, 2> = tensor.pack(y1);
  var xs: List<Tensor<Float32, 2>> = [x0h, x1h];
  var ys: List<Tensor<Float32, 2>> = [y0h, y1h];
  const eta: Float32 = 0.5;

  for epoch in 0 .. 3 {
    for sample in 0 .. xs.size() {
      const x: Tensor<Float32, 2> = xs[sample];
      const y: Tensor<Float32, 2> = ys[sample];
      var w1h: Tensor<Float32, 2> = tensor.pack(w1);
      var w2h: Tensor<Float32, 2> = tensor.pack(w2);
      var b1h: Tensor<Float32, 2> = tensor.pack(b1);
      var b2h: Tensor<Float32, 2> = tensor.pack(b2);
      var weights: List<Tensor<Float32, 2>> = [w1h, w2h];
      var biases: List<Tensor<Float32, 2>> = [b1h, b2h];

      var z1: Float32[?, ?] = matadd(
          matmul(weights[0], x),
          biases[0]);
      var a1: Float32[?, ?] = sigmoid(z1);
      var z2: Float32[?, ?] = matadd(
          matmul(weights[1], a1),
          biases[1]);
      var a2: Float32[?, ?] = sigmoid(z2);

      var delta2: Float32[?, ?] =
        hadamard(matsub(a2, y), sigmoidPrime(z2));
      var nablaW2: Float32[?, ?] = matmul(delta2, transpose(a1));

      var delta1: Float32[?, ?] =
        hadamard(matmul(transpose(weights[1]), delta2),
                 sigmoidPrime(z1));
      var nablaW1: Float32[?, ?] = matmul(delta1, transpose(x));

      w1 = matsub(weights[0], matscale(nablaW1, eta));
      w2 = matsub(weights[1], matscale(nablaW2, eta));
      b1 = matsub(biases[0], matscale(delta1, eta));
      b2 = matsub(biases[1], matscale(delta2, eta));
      ()
    };
    ()
  };

  io.print(size(w1));
  io.print(size(w2));
  io.print(size(b1));
  io.print(size(b2));
  0
}

# MLIR: scf.for unsigned
# MLIR: scf.for unsigned
# MLIR: mulberry.tensor.pack
# MLIR: call @std_collections_withCapacity__
# MLIR: call @std_collections_ListStorage_push__
# MLIR: call @std_collections_ListStorage_get__
# MLIR: mulberry.tensor.view
# MLIR: cherry_nn.matmul
# MLIR: cherry_nn.matadd
# MLIR: cherry_nn.sigmoid
# MLIR: cherry_nn.matsub
# MLIR: cherry_nn.hadamard
# MLIR: cherry_nn.sigmoid_prime
# MLIR: cherry_nn.matscale
# MLIR-NOT: memref.

# LOWER: scf.for unsigned
# LOWER: scf.for unsigned
# LOWER: linalg.generic
# LOWER: linalg.add
# LOWER: linalg.sub
# LOWER: linalg.mul
# LOWER: linalg.map
# LOWER: math.exp
# LOWER-NOT: cherry_nn.
# LOWER-NOT: mulberry.

# JIT: 2
# JIT-NEXT: 1
# JIT-NEXT: 2
# JIT-NEXT: 1
