# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var w1: Float32[?, ?] = [[0.1, 0.2], [0.3, 0.4]];
  var w2: Float32[?, ?] = [[0.5, 0.6]];
  var b1: Float32[?, ?] = [[0.01], [0.02]];
  var b2: Float32[?, ?] = [[0.03]];
  var x0: Float32[?, ?] = [[0.7], [0.8]];
  var x1: Float32[?, ?] = [[0.2], [0.4]];
  var y0: Float32[?, ?] = [[1.0]];
  var y1: Float32[?, ?] = [[0.0]];
  var xs: List<Float32[?, ?]> = [x0, x1];
  var ys: List<Float32[?, ?]> = [y0, y1];
  const eta: Float32 = 0.5;

  for epoch in 0 .. 3 {
    for sample in 0 .. collections.size(xs) {
      const x: Float32[?, ?] = collections.get(xs, sample);
      const y: Float32[?, ?] = collections.get(ys, sample);
      var weights: List<Float32[?, ?]> = [w1, w2];
      var biases: List<Float32[?, ?]> = [b1, b2];

      var z1: Float32[?, ?] = matadd(
          matmul(collections.get(weights, 0), x),
          collections.get(biases, 0));
      var a1: Float32[?, ?] = sigmoid(z1);
      var z2: Float32[?, ?] = matadd(
          matmul(collections.get(weights, 1), a1),
          collections.get(biases, 1));
      var a2: Float32[?, ?] = sigmoid(z2);

      var delta2: Float32[?, ?] =
        hadamard(matsub(a2, y), sigmoidPrime(z2));
      var nablaW2: Float32[?, ?] = matmul(delta2, transpose(a1));

      var delta1: Float32[?, ?] =
        hadamard(matmul(transpose(collections.get(weights, 1)), delta2),
                 sigmoidPrime(z1));
      var nablaW1: Float32[?, ?] = matmul(delta1, transpose(x));

      w1 = matsub(collections.get(weights, 0), matscale(nablaW1, eta));
      w2 = matsub(collections.get(weights, 1), matscale(nablaW2, eta));
      b1 = matsub(collections.get(biases, 0), matscale(delta1, eta));
      b2 = matsub(collections.get(biases, 1), matscale(delta2, eta));
      ()
    };
    ()
  };

  io.print(size(w1));
  io.print(size(w2));
  io.print(size(b1));
  io.print(size(b2));
  0
}

# MLIR: scf.for unsigned
# MLIR: scf.for unsigned
# MLIR: call @std_collections_withCapacity__Float32______
# MLIR: call @std_collections_push__Float32______
# MLIR: call @std_collections_get__Float32______
# MLIR: cherry_nn.matmul
# MLIR: cherry_nn.matadd
# MLIR: cherry_nn.sigmoid
# MLIR: cherry_nn.matsub
# MLIR: cherry_nn.hadamard
# MLIR: cherry_nn.sigmoid_prime
# MLIR: cherry_nn.matscale
# MLIR-NOT: memref.

# LOWER: scf.for unsigned
# LOWER: scf.for unsigned
# LOWER: linalg.generic
# LOWER: linalg.add
# LOWER: linalg.sub
# LOWER: linalg.mul
# LOWER: linalg.map
# LOWER: math.exp
# LOWER-NOT: cherry_nn.
# LOWER-NOT: mulberry.

# JIT: 2
# JIT-NEXT: 1
# JIT-NEXT: 2
# JIT-NEXT: 1
