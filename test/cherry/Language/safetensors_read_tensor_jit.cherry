# RUN: %numpy_python %cherry_src_root/tools/export_mnist_safetensors.py --output /tmp/cherry_safetensors_read_tensor_jit.safetensors > %t.export.log && cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

import safetensors;

fn main(): UInt64 {
  const file: File =
      io.open("/tmp/cherry_safetensors_read_tensor_jit.safetensors", "rb");
  var x: Tensor<Float32> = safetensors.readTensor(file, "x");
  var w1: Tensor<Float32> = safetensors.readTensor(file, "w1");
  io.close(file);

  io.print(x.numel());
  io.print(x.ndim());
  io.print(x.dim(0));
  io.print(x.dim(1));
  io.print(x.stride(0));
  io.print(x.stride(1));
  io.print(w1.numel());
  io.print(w1.ndim());
  io.print(w1.dim(0));
  io.print(w1.dim(1));
  io.print(w1.stride(0));
  io.print(w1.stride(1));
  0
}

