# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

struct Pair {
  x: UInt64,
  y: UInt64
}

fn main(): UInt64 {
  var xs: List<Pair> = [Pair { 10, 32 }, Pair { 4, 9 }];
  io.print(collections.size(xs));
  io.print(collections.get(xs, 0).x + collections.get(xs, 1).y);
  0
}

