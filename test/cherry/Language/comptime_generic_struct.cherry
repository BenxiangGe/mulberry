# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

comptime ListStorage<T> = struct {
  length: UInt64,
  capacity: UInt64,
  data: Ptr<T>
};

fn fill(storage: Ptr<ListStorage<UInt64>>, data: Ptr<UInt64>): UInt64 {
  storage.length = 2;
  storage.capacity = 4;
  storage.data = data;
  storage.data[0] = 11;
  storage.data[1] = 31;
  storage.length + storage.data[0] + storage.data[1]
}

fn main(): UInt64 {
  var data: Ptr<UInt64> = heap.alloc<UInt64>(2);
  var storage: Ptr<ListStorage<UInt64>> = heap.alloc<ListStorage<UInt64>>();
  io.print(fill(storage, data));
  0
}

# AST: ComptimeTypeAliasDecl {{.*}}name=ListStorage parameter=T type=struct {length: UInt64, capacity: UInt64, data: Ptr<T>}
# AST: VariableStat (id=storage
# AST-SAME: type=Ptr<ListStorage<UInt64>>

# MLIR-LABEL: func.func @fill(
# MLIR-SAME: !mulberry.ptr<!mulberry.record<ListStorage__UInt64
# MLIR-SAME: !mulberry.ptr<i64>
# MLIR: mulberry.record.get_field {{.*}}["length"]
# MLIR: mulberry.record.get_field {{.*}}["capacity"]
# MLIR: mulberry.record.get_field {{.*}}["data"]
# MLIR: mulberry.ptr.index

# MLIR-LABEL: func.func @main()
# MLIR: mulberry.heap.alloc i64
# MLIR: mulberry.heap.alloc !mulberry.record<ListStorage__UInt64
