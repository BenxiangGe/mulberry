# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver -dump=linalg %s 2>&1 | FileCheck %s --check-prefix=LINALG

fn main(): UInt64 {
  const w1: Float32[2] = [1.0, 2.0];
  const w2: Float32[2] = [3.0, 4.0];
  const weights: List<Float32[?]> = [w1, w2];
  var index: UInt64 = 1;
  const selected: Float32[?] = weights[index];
  var pred: UInt64 = argmax(selected);
  pred
}

# MLIR: mulberry.list.create
# MLIR-SAME: !mulberry.list<!mulberry.tensor_desc<memref<?xf32>>>
# MLIR: mulberry.list.get
# MLIR-SAME: <!mulberry.tensor_desc<memref<?xf32>>> -> !mulberry.tensor_desc<memref<?xf32>>
# MLIR: mulberry.tensor.unpack
# MLIR-SAME: <memref<?xf32>> -> memref<?xf32>

# LINALG-NOT: mulberry.list
# LINALG-NOT: scf.index_switch
# LINALG: memref.load
