# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR
# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s --check-prefix=LOWER
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn main(): UInt64 {
  var a: Float32[2, 2] = [[1.0, 2.0], [3.0, 4.0]];
  var b: Float32[2, 2] = matscale(a, -1.0);

  print(argmax(b));
  0
}

# MLIR: mulberry.tensor.alloc() : !mulberry.tensor<2x2xf32>
# MLIR: mulberry.tensor.alloc() : !mulberry.tensor<2x2xf32>
# MLIR: cherry_nn.matscale
# MLIR-SAME: !mulberry.tensor<2x2xf32>, f32
# MLIR-NOT: memref.

# LOWER: linalg.map
# LOWER: arith.mulf
# LOWER-NOT: cherry_nn.
# LOWER-NOT: mulberry.

# JIT: 0
