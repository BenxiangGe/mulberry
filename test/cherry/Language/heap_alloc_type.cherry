# RUN: cherry-driver -dump=ast %s 2>&1 | FileCheck %s --check-prefix=AST
# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s --check-prefix=MLIR

struct Pair {
  x: UInt64,
  y: Bool
}

fn makeUInt64(): Ptr<UInt64> {
  heap.alloc<UInt64>()
}

fn makePair(): Ptr<Pair> {
  heap.alloc<Pair>()
}

fn makeList(): Ptr<List<UInt64>> {
  heap.alloc<List<UInt64>>()
}

fn main(): UInt64 {
  0
}

# AST: HeapAllocExpr {{.*}}type=Ptr<UInt64> allocated=UInt64
# AST: HeapAllocExpr {{.*}}type=Ptr<Pair> allocated=Pair
# AST: HeapAllocExpr {{.*}}type=Ptr<List<UInt64>> allocated=List<UInt64>

# MLIR-LABEL: func.func @makeUInt64() -> !mulberry.ptr<i64>
# MLIR: %[[ONE:.*]] = arith.constant 1 : index
# MLIR: mulberry.heap.alloc i64, %[[ONE]] : !mulberry.ptr<i64>
# MLIR-LABEL: func.func @makePair() -> !mulberry.ptr<!mulberry.record<Pair
# MLIR: %[[ONE:.*]] = arith.constant 1 : index
# MLIR: mulberry.heap.alloc !mulberry.record<Pair{{.*}}, %[[ONE]]
# MLIR-LABEL: func.func @makeList() -> !mulberry.ptr<!mulberry.list<i64>>
# MLIR: %[[ONE:.*]] = arith.constant 1 : index
# MLIR: mulberry.heap.alloc !mulberry.list<i64>, %[[ONE]] : !mulberry.ptr<!mulberry.list<i64>>
