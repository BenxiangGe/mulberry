# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  io.print(20 + 10);
  io.print(18446744073709551615 + 0);
  io.print(18446744073709551615 + 1);

  io.print(20 - 10);
  io.print(0 - 1);

  io.print(20 * 10);

  io.print(20 / 10);
  io.print(20 / 3);

  io.print(20 % 10);
  io.print(20 % 3);

  io.print(boolToUInt64(20 lt 10));
  io.print(boolToUInt64(10 lt 20));
  io.print(boolToUInt64(10 lt 10));

  io.print(boolToUInt64(20 le 10));
  io.print(boolToUInt64(10 le 20));
  io.print(boolToUInt64(10 le 10));

  io.print(boolToUInt64(20 gt 10));
  io.print(boolToUInt64(10 gt 20));
  io.print(boolToUInt64(10 gt 10));

  io.print(boolToUInt64(20 ge 10));
  io.print(boolToUInt64(10 ge 20));
  io.print(boolToUInt64(10 ge 10));

  io.print(boolToUInt64(20 eq 10));
  io.print(boolToUInt64(10 ge 20));
  io.print(boolToUInt64(10 eq 10));

  io.print(boolToUInt64(20 neq 10));
  io.print(boolToUInt64(10 neq 20));
  io.print(boolToUInt64(10 neq 10));

  io.print(boolToUInt64(true eq true));
  io.print(boolToUInt64(true eq false));

  io.print(boolToUInt64(true neq true));
  io.print(boolToUInt64(true neq false));

  io.print(boolToUInt64(false and false));
  io.print(boolToUInt64(false and true));
  io.print(boolToUInt64(true and false));
  io.print(boolToUInt64(true and true));

  io.print(boolToUInt64(false or false));
  io.print(boolToUInt64(false or true));
  io.print(boolToUInt64(true or false));
  io.print(boolToUInt64(true or true));

  0
}

# CHECK: arith.addi
# CHECK: arith.subi
# CHECK: arith.muli
# CHECK: arith.divui
# CHECK: arith.remui
# CHECK: arith.cmpi ult
# CHECK: arith.cmpi ule
# CHECK: arith.cmpi ugt
# CHECK: arith.cmpi uge
# CHECK: arith.cmpi eq
# CHECK: arith.cmpi ne
# CHECK: arith.andi
# CHECK: arith.ori
# CHECK: call @std.core.boolToUInt64
# CHECK: call @std.io.print
# CHECK-NOT: cir.
