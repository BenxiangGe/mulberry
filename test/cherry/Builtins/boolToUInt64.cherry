# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  io.print(boolToUInt64(true));
  
  io.print(boolToUInt64(false));

  0
}

# CHECK: arith.extui
# CHECK-SAME: i1 to i64
# CHECK: call @std.io.print
# CHECK: arith.extui
# CHECK-SAME: i1 to i64
# CHECK: call @std.io.print
# CHECK-NOT: cir.
