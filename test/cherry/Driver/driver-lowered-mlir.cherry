# RUN: cherry-driver --dump=lowered-mlir %s 2>&1 | FileCheck %s

fn main(): UInt64 {
  var a: Float32[4] = [1.0, 9.0, 3.0, 2.0];
  argmax(a)
}

# CHECK-LABEL: func.func @main
# CHECK: llvm.alloca %{{.*}} x !llvm.struct<(ptr, array<1 x i64>, array<1 x i64>)>
# CHECK: linalg.generic
# CHECK: return
# CHECK-NOT: cherry_nn.
# CHECK-NOT: mulberry.
