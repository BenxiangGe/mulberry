# RUN: cherry-driver %s -dump=mlir-llvm 2>&1 | FileCheck %s --check-prefix=MLIRLLVM
# RUN: cherry-driver %s -dump=llvm 2>&1 | FileCheck %s --check-prefix=LLVM
# RUN: cherry-driver %s 2>&1 | FileCheck %s --check-prefix=JIT

fn bar(x: UInt64, y: Bool): Bool {
  var k: Bool = y;
  
  k = if k {
    print(18446744073709551615);
    false
  } else {
    print(1);
    true
  };

  var unit: () = while k {
    k = false;
    ()
  };

  k
}

fn baz(): () {
  ()
}

fn main(): UInt64 {
  0 % 3 * 8 / 4 + 3 - 1;
  3 lt 1; 3 le 1; 3 gt 1; 3 ge 1;
  true and false or true eq false neq true;

  var boolValue: Bool = bar(18446744073709551615, false);
  print(boolToUInt64(boolValue));
  baz();
  0
}

# MLIRLLVM: llvm.func @printU64(i64)
# MLIRLLVM: llvm.func @main() -> i64
# MLIRLLVM: llvm.call @printU64
# MLIRLLVM: llvm.func @_mlir_ciface_main() -> i64
# MLIRLLVM-NOT: cherry.
# MLIRLLVM-NOT: func.func
# MLIRLLVM-NOT: builtin.unrealized_conversion_cast

# LLVM: declare void @printU64(i64)
# LLVM: define i64 @main()
# LLVM: call void @printU64
# LLVM: define i64 @_mlir_ciface_main()

# JIT: 1
# JIT-NEXT: 0
