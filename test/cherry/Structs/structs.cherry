# RUN: cherry-driver -dump=mlir %s 2>&1 | FileCheck %s

struct A { }

struct B {
  a: A,
  y: UInt64
}

struct C {
  b: B,
  x: UInt64
}

fn main(): UInt64 {
  var c: C = C { B { A {}, 2 }, 1 };
  io.print(c.x);
  c.x = 11;
  io.print(c.x);

  io.print(c.b.y);
  c.b.y = 22;
  io.print(c.b.y);
  0
}

# CHECK: !mulberry.record<C
# CHECK-SAME: !mulberry.record<B
# CHECK-SAME: !mulberry.record<A {}
# CHECK: mulberry.record.get_field
# CHECK: mulberry.store
# CHECK: call @std.io.print
# CHECK-NOT: cir.
