ERROR(func_param, "function `%s` takes %d parameters")

ERROR(mismatch_type, "type mismatch")
ERROR(wrong_return_type, "wrong return type")
ERROR(wrong_num_arg, "wrong number of arguments")
ERROR(unexpected_unit_type, "unexpected unit type")
ERROR(unsupported_type_layout, "unsupported type layout")
ERROR(internal_only, "internal feature is not available to user code")

ERROR(expected_bool, "expected Bool")
ERROR(expected_field, "expected struct field")
ERROR(expected_expr, "expected expression")
ERROR(expected_lvalue, "expected lvalue")
ERROR(assign_const, "cannot assign to const variable")
ERROR(const_to_mutable, "cannot bind const object to mutable reference")
ERROR(loop_control_outside_loop, "`break` or `continue` outside loop")
ERROR(return_outside_function, "`return` outside function")

ERROR(undefined_field, "undefined field")
ERROR(undefined_func, "cannot find function `%s`")
ERROR(undefined_main, "undefined symbol `main` : () -> UInt64")
ERROR(undefined_type, "undefined type")
ERROR(undefined_var, "undefined variable")

ERROR(redefinition_func, "redefinition of `%s`")
ERROR(redefinition_type, "redefinition of type")
ERROR(redefinition_var, "redefinition of variable")

// ___________________________________________________________________________
#undef ERROR
