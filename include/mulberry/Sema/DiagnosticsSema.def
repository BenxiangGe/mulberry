ERROR(func_param, "function `%s` takes %d parameters")

ERROR(mismatch_type, "type mismatch")
ERROR(wrong_return_type, "wrong return type")
ERROR(wrong_num_arg, "wrong number of arguments")
ERROR(unexpected_unit_type, "unexpected unit type")
ERROR(unsupported_type_layout, "unsupported type layout")
ERROR(internal_only, "internal feature is not available to user code")
ERROR(expected_comptime_value, "expected a comptime value")
ERROR(expected_comptime_type, "expected a comptime Type")
ERROR(comptime_type_runtime, "comptime Type cannot be used as a runtime value")
ERROR(extern_function_value,
      "extern function cannot be used as a function value")
ERROR(lambda_expected_function_type,
      "lambda requires an expected function type")
ERROR(lambda_capture,
      "noncapturing lambda cannot capture a local variable")
ERROR(invalid_reflection_query, "reflection query is not valid for this type")

ERROR(expected_bool, "expected Bool")
ERROR(expected_field, "expected struct field")
ERROR(expected_expr, "expected expression")
ERROR(expected_lvalue, "expected lvalue")
ERROR(assign_const, "cannot assign to const variable")
ERROR(readonly_to_mutable_binding,
      "cannot bind readonly object to mutable variable")
ERROR(readonly_to_mutable_reference,
      "cannot use readonly object as mutable reference")
ERROR(loop_control_outside_loop, "`break` or `continue` outside loop")
ERROR(return_outside_function, "`return` outside function")
ERROR(match_expected_data_type, "match value must have a data type")
ERROR(match_constructor_type,
      "match constructor does not belong to the matched data type")
ERROR(match_binding_count,
      "match pattern has the wrong number of payload bindings")
ERROR(duplicate_match_constructor, "duplicate constructor in match")
ERROR(non_exhaustive_match, "match must cover every constructor exactly once")
ERROR(match_expression_arm_return,
      "match expression arm must produce its value with terminal `yield`")
ERROR(try_expected_result, "`?` operand must have type `Result<T, E>`")
ERROR(try_outside_result_function,
      "`?` requires the current function to return `Result<T, E>`")
ERROR(try_error_type_mismatch,
      "`?` error type must match the current function error type")

ERROR(undefined_field, "undefined field")
ERROR(undefined_func, "cannot find function `%s`")
ERROR(undefined_main, "undefined symbol `main` : () -> UInt64")
ERROR(undefined_type, "undefined type")
ERROR(undefined_var, "undefined variable")
ERROR(undefined_data_constructor, "undefined data constructor")
ERROR(undefined_trait, "cannot find trait `%s`")

ERROR(redefinition_func, "redefinition of `%s`")
ERROR(redefinition_type, "redefinition of type")
ERROR(redefinition_var, "redefinition of variable")
ERROR(redefinition_data_constructor, "redefinition of data constructor")
ERROR(redefinition_trait, "redefinition of trait `%s`")
ERROR(redefinition_trait_impl,
      "trait `%s` is already implemented for this type")
ERROR(trait_method_signature,
      "trait method `%s` has an incompatible signature")
ERROR(missing_trait_method,
      "trait implementation is missing method `%s`")
ERROR(trait_constraint,
      "type `%t` does not satisfy trait `%s`")

// ___________________________________________________________________________
#undef ERROR
